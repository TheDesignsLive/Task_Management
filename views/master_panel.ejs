<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Master Panel</title>
<link rel="icon" type="image/svg" href="/images/tms.svg">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
    /* ===== BASE STYLES ===== */
    html, body { margin: 0; padding: 0; height: 100%; font-family: 'Segoe UI', Arial, sans-serif; background-color: #3C3A3A; color: #fff; }
    .layout { display: flex; height: calc(100vh - 60px); }
    .main-content { flex: 1; padding: 20px; overflow-y: auto; display: flex; flex-direction: column; gap: 20px; }

    /* ===== HEADER ===== */
    .header-card { background: #2E2D2D; border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 20px; }
    .header-card h1 { margin: 0; color: #00d1b2; font-size: 24px; }
    .header-card p { margin: 5px 0 0 0; color: #aaa; font-size: 14px; }

    /* ===== TABLE STYLES ===== */
    .table-container { background: #2E2D2D; border-radius: 8px; border: 1px solid rgba(255,255,255,0.05); overflow-x: auto; }
    table.main-table { width: 100%; border-collapse: collapse; text-align: left; min-width: 1000px; }
    table.main-table > thead > tr > th, table.main-table > tbody > tr.main-row > td { padding: 15px; border-bottom: 1px solid rgba(255,255,255,0.1); font-size: 14px; }
    table.main-table > thead > tr > th { color: #00d1b2; font-weight: 600; text-transform: uppercase; font-size: 12px; background: rgba(0,0,0,0.2); }
    table.main-table > tbody > tr.main-row:hover { background: #444; }
    
    .company-name { font-weight: bold; color: #fff; font-size: 15px; }
    .admin-email { font-size: 12px; color: #aaa; }
    
    .metric-badge { background: #444; padding: 4px 8px; border-radius: 6px; font-weight: bold; font-size: 12px; color: #fff; }
    .metric-highlight { color: #f39c12; }
    .metric-success { color: #2ecc71; }

    /* ===== BUTTONS ===== */
    .action-group { display: flex; gap: 10px; align-items: center; }
    .view-btn { 
        display: inline-flex; 
        align-items: center; 
        gap: 6px; 
        background: #0F8989; 
        color: white; 
        text-decoration: none; 
        padding: 8px 15px; 
        border-radius: 6px; 
        font-weight: bold; 
        font-size: 12px; 
        transition: 0.2s; 
    }
    .view-btn:hover { background: #0c7575; transform: translateY(-1px); }
    .expand-btn { background: #555; color: white; border: none; padding: 8px 12px; border-radius: 6px; cursor: pointer; transition: 0.2s; font-size: 12px; font-weight: bold; }
    .expand-btn:hover { background: #777; }

    /* ===== NESTED ACCORDION STYLES ===== */
    .expanded-row td { padding: 0 !important; border: none !important; }
    .expanded-content { background: #2E2D2D; border-bottom: 2px solid #00d1b2; box-shadow: inset 0 5px 15px rgba(0,0,0,0.3); padding: 20px; display: flex; flex-direction: column; gap: 15px; }
    
    /* Level 2: The Main Categories (Users, Teams, Tasks) */
    .acc-section { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 6px; overflow: hidden; }
    .acc-header { padding: 12px 15px; font-size: 14px; font-weight: bold; cursor: pointer; display: flex; justify-content: space-between; align-items: center; background: rgba(0,0,0,0.2); transition: 0.2s; color: #00d1b2; }
    .acc-header:hover { background: rgba(0,0,0,0.4); }
    .acc-body { padding: 10px; display: none; } /* Hidden by default */

    /* Level 3 & 4: Sub-Lists and Details */
    .sub-item { border-bottom: 1px solid rgba(255,255,255,0.05); margin-bottom: 5px; padding-bottom: 5px; }
    .sub-item:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
    .sub-header { padding: 10px; font-size: 13px; cursor: pointer; display: flex; justify-content: space-between; align-items: center; border-radius: 4px; transition: 0.2s; background: rgba(255,255,255,0.02); }
    .sub-header:hover { background: rgba(255,255,255,0.06); }
    .sub-body { padding: 10px 15px; font-size: 12px; color: #ccc; background: rgba(0,0,0,0.15); border-radius: 4px; margin-top: 4px; display: none; line-height: 1.6; }

    /* Filter Bar */
    .filter-bar { display: flex; gap: 15px; background: rgba(0,0,0,0.2); padding: 10px 15px; border-radius: 6px; align-items: center; margin-bottom: 10px; }
    .filter-bar input, .filter-bar select { padding: 6px 10px; border-radius: 4px; border: 1px solid #555; background: #3C3A3A; color: white; font-size: 12px; }

    /* Custom Scrollbar */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #555; border-radius: 10px; }
</style>
</head>
<body>

<div class="layout">
    <div class="main-content">
        <div class="header-card">
            <h1>Master Panel</h1>
            <p>Global overview of all registered companies and deep-dive analytics.</p>
        </div>

        <div class="table-container">
            <table class="main-table">
                <thead>
                    <tr>
                        <th>No</th>
                        <th>Admin Name</th>
                        <th>Company Name</th>
                        <th>Gmail</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (companies.length > 0) { %>
                        <% companies.forEach((company, index) => { %>
                            <tr class="main-row">
                               <td style="color: #aaa;"><%= index + 1 %></td>
                                <td><strong><%= company.admin_name %></strong></td>
                                <td><%= company.company_name || 'Unnamed Company' %></td>
                                <td><%= company.email %></td>
                                <td>
                                    <div class="action-group">
                                        <a href="/masterpage/impersonate/<%= company.id %>" target="_blank" class="view-btn">
                                            <i class="fa-solid fa-arrow-up-right-from-square"></i> View
                                        </a>
                                        <button class="expand-btn" onclick="toggleCompanyDetails('<%= company.id %>')">
                                            <i class="fa-solid fa-chevron-down" id="icon-<%= company.id %>"></i> Expand
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            <tr id="expanded-<%= company.id %>" class="expanded-row" style="display:none;">
                                <td colspan="5">
                                    <div class="expanded-content" id="content-<%= company.id %>">
                                        </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" style="text-align: center; padding: 30px; color: #aaa;">No companies registered yet.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    const companyDataCache = {};

    // 1. Toggle the entire company row
    async function toggleCompanyDetails(companyId) {
        const row = document.getElementById(`expanded-${companyId}`);
        const contentDiv = document.getElementById(`content-${companyId}`);
        const icon = document.getElementById(`icon-${companyId}`);

        if (row.style.display === 'table-row') {
            row.style.display = 'none';
            icon.classList.replace('fa-chevron-up', 'fa-chevron-down');
            return;
        }

        // Close all others
        document.querySelectorAll('.expanded-row').forEach(r => r.style.display = 'none');
        document.querySelectorAll('.expand-btn i').forEach(i => i.classList.replace('fa-chevron-up', 'fa-chevron-down'));

        row.style.display = 'table-row';
        icon.classList.replace('fa-chevron-down', 'fa-chevron-up');

        // Fetch data if not cached
        if (!companyDataCache[companyId]) {
            contentDiv.innerHTML = '<div style="text-align:center; padding: 30px; color: #00d1b2;"><i class="fa-solid fa-spinner fa-spin fa-2x"></i><p>Loading Data...</p></div>';
            
            try {
                const res = await fetch(`/masterpage/api/company-details/${companyId}`);
                const data = await res.json();
                if(data.success) {
                    companyDataCache[companyId] = data;
                    renderNestedAccordion(companyId);
                } else {
                    contentDiv.innerHTML = '<div style="color:#e74c3c; text-align:center;">Failed to load data.</div>';
                }
            } catch (err) {
                contentDiv.innerHTML = '<div style="color:#e74c3c; text-align:center;">Server Error.</div>';
            }
        } else {
            renderNestedAccordion(companyId);
        }
    }

    // 2. Generic function to toggle any nested accordion body
    function toggleNested(id) {
        const body = document.getElementById(`body-${id}`);
        const icon = document.querySelector(`.icon-${id}`);
        
        if (body.style.display === 'block') {
            body.style.display = 'none';
            if(icon) icon.classList.replace('fa-chevron-up', 'fa-chevron-down');
        } else {
            body.style.display = 'block';
            if(icon) icon.classList.replace('fa-chevron-down', 'fa-chevron-up');
        }
    }

    // 3. Render the nested UI structure
    function renderNestedAccordion(companyId) {
        const data = companyDataCache[companyId];
        const contentDiv = document.getElementById(`content-${companyId}`);

        let html = `
            <div class="acc-section">
                <div class="acc-header" onclick="toggleNested('users-${companyId}')">
                    <span><i class="fa-solid fa-users" style="margin-right:8px;"></i> Total Users: ${data.users.length}</span>
                    <i class="fa-solid fa-chevron-down icon-users-${companyId}"></i>
                </div>
                <div class="acc-body" id="body-users-${companyId}">
                    ${data.users.map(u => `
                        <div class="sub-item">
                            <div class="sub-header" onclick="toggleNested('user-${u.id}')">
                                <span><strong>${u.name}</strong></span>
                                <i class="fa-solid fa-chevron-down icon-user-${u.id}"></i>
                            </div>
                            <div class="sub-body" id="body-user-${u.id}">
                                <strong>Email:</strong> ${u.email}<br>
                                <strong>Phone:</strong> ${u.phone || 'N/A'}<br>
                                <strong>Role:</strong> ${u.role_name || 'None'}<br>
                                <strong>Control Type:</strong> <span style="color:#f39c12;">${u.control_type || 'NONE'}</span><br>
                                <strong>Status:</strong> ${u.status}
                            </div>
                        </div>
                    `).join('') || '<div style="padding:10px; color:#aaa; font-size:13px;">No users found.</div>'}
                </div>
            </div>

            <div class="acc-section">
                <div class="acc-header" onclick="toggleNested('teams-${companyId}')">
                    <span><i class="fa-solid fa-sitemap" style="margin-right:8px;"></i> Total Teams: ${data.teams.length}</span>
                    <i class="fa-solid fa-chevron-down icon-teams-${companyId}"></i>
                </div>
                <div class="acc-body" id="body-teams-${companyId}">
                    ${data.teams.map(t => `
                        <div class="sub-item">
                            <div class="sub-header" onclick="toggleNested('team-${t.id}')">
                                <span><strong>${t.name}</strong></span>
                                <i class="fa-solid fa-chevron-down icon-team-${t.id}"></i>
                            </div>
                            <div class="sub-body" id="body-team-${t.id}">
                                <strong>Total Members Assigned:</strong> ${t.user_count}<br>
                                <strong>Created At:</strong> ${new Date(t.created_at).toLocaleDateString()}
                            </div>
                        </div>
                    `).join('') || '<div style="padding:10px; color:#aaa; font-size:13px;">No teams found.</div>'}
                </div>
            </div>

            <div class="acc-section">
                <div class="acc-header" onclick="toggleNested('tasks-${companyId}')">
                    <span><i class="fa-solid fa-list-check" style="margin-right:8px;"></i> Total Tasks: ${data.tasks.length}</span>
                    <i class="fa-solid fa-chevron-down icon-tasks-${companyId}"></i>
                </div>
                <div class="acc-body" id="body-tasks-${companyId}">
                    <div class="filter-bar">
                        <label>Date:</label>
                        <input type="date" id="dateFilter-${companyId}" onchange="filterTasks('${companyId}')">
                        <label>Section:</label>
                        <select id="sectionFilter-${companyId}" onchange="filterTasks('${companyId}')">
                            <option value="ALL">All Sections</option>
                            <option value="OPEN">All Open</option>
                            <option value="COMPLETED">Completed</option>
                            <option value="TASK">Task</option>
                            <option value="CHANGES">Changes</option>
                            <option value="UPDATE">Update</option>
                            <option value="OTHERS">Others</option>
                        </select>
                    </div>
                    <div id="taskBody-${companyId}" style="margin-top:10px;">
                        </div>
                </div>
            </div>
        `;

        contentDiv.innerHTML = html;
        filterTasks(companyId); // Render tasks initially
    }

    // 4. Task Filtering logic
    function filterTasks(companyId) {
        const tasks = companyDataCache[companyId].tasks;
        const dateFilter = document.getElementById(`dateFilter-${companyId}`).value;
        const sectionFilter = document.getElementById(`sectionFilter-${companyId}`).value;
        const tbody = document.getElementById(`taskBody-${companyId}`);

        let filtered = tasks;

        if (dateFilter) filtered = filtered.filter(t => t.due_date === dateFilter);

        if (sectionFilter !== 'ALL') {
            if (sectionFilter === 'COMPLETED') filtered = filtered.filter(t => t.status === 'COMPLETED');
            else if (sectionFilter === 'OPEN') filtered = filtered.filter(t => t.status !== 'COMPLETED');
            else filtered = filtered.filter(t => t.status !== 'COMPLETED' && t.section === sectionFilter);
        }

        tbody.innerHTML = filtered.map(t => `
            <div class="sub-item" style="cursor:default;">
                <div class="sub-header" style="background:transparent; cursor:default; border-bottom:1px dashed rgba(255,255,255,0.1);">
                    <span><strong>${t.title}</strong></span>
                    <span style="font-size:11px; color:#aaa;">
                        Section: ${t.section || 'TASK'} | 
                        Priority: ${t.priority} | 
                        Status: <strong style="${t.status === 'COMPLETED' ? 'color:#2ecc71;' : 'color:#f39c12;'}">${t.status}</strong> | 
                        Due: ${t.due_date || 'No Date'}
                    </span>
                </div>
            </div>
        `).join('') || '<div style="padding:10px; color:#aaa; font-size:13px;">No tasks match filters.</div>';
    }
</script>

</body>
</html>