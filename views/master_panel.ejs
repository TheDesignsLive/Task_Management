let accessToken = "";

function connectGoogle() {
  const client = google.accounts.oauth2.initTokenClient({
    client_id: "YOUR_GOOGLE_CLIENT_ID",
    scope: "https://www.googleapis.com/auth/drive.file https://www.googleapis.com/auth/userinfo.email",
    callback: (tokenResponse) => {
      accessToken = tokenResponse.access_token;
      loadPicker();
    }
  });

  client.requestAccessToken();
}



function showPopup(message, type="success") {
    const popup = document.getElementById("popup");

    popup.innerText = message;
    popup.style.display = "block";

    popup.style.background = type === "error" ? "#e74c3c" : "#2ecc71";

    // animate in
    setTimeout(() => {
        popup.style.opacity = "1";
        popup.style.transform = "translateX(-50%) translateY(0)";
    }, 10);

    // hide after 2 sec
    setTimeout(() => {
        popup.style.opacity = "0";
        popup.style.transform = "translateX(-50%) translateY(-20px)";

        setTimeout(() => {
            popup.style.display = "none";
        }, 300);
    }, 2000);
}

// STEP 1: SEND OTP (NO EMAIL INPUT)


async function verifyImportOTP() {
    const otpInput = document.getElementById("importOTP");
    const otp = otpInput.value.trim();

    if (otp.length !== 6) {
        showPopup("Enter valid 6-digit OTP", "error");
        return;
    }

    try {
        const res = await fetch("/import/verify-otp", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            credentials: "include",
            body: JSON.stringify({ otp })
        });

        // 🔥 HANDLE NON-JSON RESPONSE
        let data;
        try {
            data = await res.json();
        } catch {
            showPopup("Invalid server response ❌", "error");
            return;
        }

        // 🔥 HANDLE HTTP ERROR
        if (!res.ok) {
            showPopup(data.message || "Server error ❌", "error");
            return;
        }

        // ✅ SUCCESS
        if (data.success === true) {
            showPopup("OTP Verified ");

            document.getElementById("otpSection").style.display = "none";
            document.getElementById("fileSection").style.display = "block";
        } 
        // ❌ INVALID OTP
        else {
            showPopup(data.message || "Invalid OTP ", "error");

            otpInput.value = "";
            otpInput.focus();

            otpInput.style.borderColor = "#e74c3c";
            otpInput.style.transform = "translateX(6px)";

            setTimeout(() => {
                otpInput.style.transform = "translateX(0)";
                otpInput.style.borderColor = "#444";
            }, 250);
        }

    } catch (err) {
        console.error(err);
        showPopup("Network error ❌", "error");
    }
}

// STEP 3: UPLOAD FILE
async function uploadSQL() {
    const file = document.getElementById("importFile").files[0];

    if (!file) {
        showPopup("Select file", "error");
        return;
    }

    if (!file.name.endsWith(".sql")) {
        showPopup("Only .sql file allowed", "error");
        return;
    }

    const formData = new FormData();
    formData.append("file", file);

  const res = await fetch("/import/upload", {
    method: "POST",
    body: formData,
    credentials: "include"   // 🔥 MUST ADD
});

    const data = await res.json();

    if (data.success) {
        showPopup("Database Imported ✅");
        closeImportModal();
    } else {
        showPopup("Import Failed ❌", "error");
    }
}


async function openImportModal() {
    document.getElementById("importModal").style.display = "flex";

    // reset UI
    document.getElementById("otpSection").style.display = "block";
    document.getElementById("fileSection").style.display = "none";
const otpInput = document.getElementById("importOTP");
otpInput.value = "";
otpInput.focus();

    try {
        const res = await fetch("/import/send-otp", {
    method: "POST",
    credentials: "include"   // ✅ ADD THIS
});

        const data = await res.json();

        if (data.success) {
            showPopup("OTP sent to super admin email ");
        } else {
            showPopup("Failed to send OTP ❌", "error");
        }
    } catch (err) {
        
    }
}

//  prevent single click outside
document.getElementById("importModal").addEventListener("click", function(e) {
    if (e.target.id === "importModal") {
        // do nothing (disable close)
    }
});
//  double click outside = close
document.getElementById("importModal").addEventListener("dblclick", function(e) {
    if (e.target.id === "importModal") {
        closeImportModal();
    }
});






