<script>
    const companyDataCache = {};

    // 1. Toggle the entire company row
    async function toggleCompanyDetails(companyId) {
        const row = document.getElementById(`expanded-${companyId}`);
        const contentDiv = document.getElementById(`content-${companyId}`);
        const icon = document.getElementById(`icon-${companyId}`);

        if (row.style.display === 'table-row') {
            row.style.display = 'none';
            icon.classList.replace('fa-chevron-up', 'fa-chevron-down');
            return;
        }

        // Close all others
        document.querySelectorAll('.expanded-row').forEach(r => r.style.display = 'none');
        document.querySelectorAll('.expand-btn i').forEach(i => i.classList.replace('fa-chevron-up', 'fa-chevron-down'));

        row.style.display = 'table-row';
        icon.classList.replace('fa-chevron-down', 'fa-chevron-up');

        // Fetch data if not cached
        if (!companyDataCache[companyId]) {
            contentDiv.innerHTML = '<div style="text-align:center; padding: 30px; color: #00d1b2;"><i class="fa-solid fa-spinner fa-spin fa-2x"></i><p>Loading Data...</p></div>';
            
            try {
                const res = await fetch(`/masterpage/api/company-details/${companyId}`);
                const data = await res.json();
                if(data.success) {
                    companyDataCache[companyId] = data;
                    renderNestedAccordion(companyId);
                } else {
                    contentDiv.innerHTML = '<div style="color:#e74c3c; text-align:center;">Failed to load data.</div>';
                }
            } catch (err) {
                contentDiv.innerHTML = '<div style="color:#e74c3c; text-align:center;">Server Error.</div>';
            }
        } else {
            renderNestedAccordion(companyId);
        }
    }

    // 2. Generic function to toggle any nested accordion body
    function toggleNested(id) {
        const body = document.getElementById(`body-${id}`);
        const icon = document.querySelector(`.icon-${id}`);
        
        if (body.style.display === 'block') {
            body.style.display = 'none';
            if(icon) icon.classList.replace('fa-chevron-up', 'fa-chevron-down');
        } else {
            body.style.display = 'block';
            if(icon) icon.classList.replace('fa-chevron-down', 'fa-chevron-up');
        }
    }

    // 3. Render the nested UI structure
    function renderNestedAccordion(companyId) {
        const data = companyDataCache[companyId];
        const contentDiv = document.getElementById(`content-${companyId}`);

        let html = `
            <div class="acc-section">
                <div class="acc-header" onclick="toggleNested('users-${companyId}')">
                    <span><i class="fa-solid fa-users" style="margin-right:8px;"></i> Total Users: ${data.users.length}</span>
                    <i class="fa-solid fa-chevron-down icon-users-${companyId}"></i>
                </div>
                <div class="acc-body" id="body-users-${companyId}">
                    ${data.users.map(u => `
                        <div class="sub-item">
                            <div class="sub-header" onclick="toggleNested('user-${u.id}')">
                                <span><strong>${u.name}</strong></span>
                                <i class="fa-solid fa-chevron-down icon-user-${u.id}"></i>
                            </div>
                            <div class="sub-body" id="body-user-${u.id}">
                                <strong>Email:</strong> ${u.email}<br>
                                <strong>Phone:</strong> ${u.phone || 'N/A'}<br>
                                <strong>Role:</strong> ${u.role_name || 'None'}<br>
                                <strong>Control Type:</strong> <span style="color:#f39c12;">${u.control_type || 'NONE'}</span><br>
                                <strong>Status:</strong> ${u.status}
                            </div>
                        </div>
                    `).join('') || '<div style="padding:10px; color:#aaa; font-size:13px;">No users found.</div>'}
                </div>
            </div>

            <div class="acc-section">
                <div class="acc-header" onclick="toggleNested('teams-${companyId}')">
                    <span><i class="fa-solid fa-sitemap" style="margin-right:8px;"></i> Total Teams: ${data.teams.length}</span>
                    <i class="fa-solid fa-chevron-down icon-teams-${companyId}"></i>
                </div>
                <div class="acc-body" id="body-teams-${companyId}">
                    ${data.teams.map(t => `
                        <div class="sub-item">
                            <div class="sub-header" onclick="toggleNested('team-${t.id}')">
                                <span><strong>${t.name}</strong></span>
                                <i class="fa-solid fa-chevron-down icon-team-${t.id}"></i>
                            </div>
                            <div class="sub-body" id="body-team-${t.id}">
                                <strong>Total Members Assigned:</strong> ${t.user_count}<br>
                                <strong>Created At:</strong> ${new Date(t.created_at).toLocaleDateString()}
                            </div>
                        </div>
                    `).join('') || '<div style="padding:10px; color:#aaa; font-size:13px;">No teams found.</div>'}
                </div>
            </div>

            <div class="acc-section">
                <div class="acc-header" onclick="toggleNested('tasks-${companyId}')">
                    <span><i class="fa-solid fa-list-check" style="margin-right:8px;"></i> Total Tasks: ${data.tasks.length}</span>
                    <i class="fa-solid fa-chevron-down icon-tasks-${companyId}"></i>
                </div>
                <div class="acc-body" id="body-tasks-${companyId}">
                    <div class="filter-bar">
                        <label>Date:</label>
                        <input type="date" id="dateFilter-${companyId}" onchange="filterTasks('${companyId}')">
                        <label>Section:</label>
                        <select id="sectionFilter-${companyId}" onchange="filterTasks('${companyId}')">
                            <option value="ALL">All Sections</option>
                            <option value="OPEN">All Open</option>
                            <option value="COMPLETED">Completed</option>
                            <option value="TASK">Task</option>
                            <option value="CHANGES">Changes</option>
                            <option value="UPDATE">Update</option>
                            <option value="OTHERS">Others</option>
                        </select>
                    </div>
                    <div id="taskBody-${companyId}" style="margin-top:10px;">
                        </div>
                </div>
            </div>
        `;

        contentDiv.innerHTML = html;
        filterTasks(companyId); // Render tasks initially
    }

    // 4. Task Filtering logic
    function filterTasks(companyId) {
        const tasks = companyDataCache[companyId].tasks;
        const dateFilter = document.getElementById(`dateFilter-${companyId}`).value;
        const sectionFilter = document.getElementById(`sectionFilter-${companyId}`).value;
        const tbody = document.getElementById(`taskBody-${companyId}`);

        let filtered = tasks;

        if (dateFilter) filtered = filtered.filter(t => t.due_date === dateFilter);

        if (sectionFilter !== 'ALL') {
            if (sectionFilter === 'COMPLETED') filtered = filtered.filter(t => t.status === 'COMPLETED');
            else if (sectionFilter === 'OPEN') filtered = filtered.filter(t => t.status !== 'COMPLETED');
            else filtered = filtered.filter(t => t.status !== 'COMPLETED' && t.section === sectionFilter);
        }

        tbody.innerHTML = filtered.map(t => `
            <div class="sub-item" style="cursor:default;">
                <div class="sub-header" style="background:transparent; cursor:default; border-bottom:1px dashed rgba(255,255,255,0.1);">
                    <span><strong>${t.title}</strong></span>
                    <span style="font-size:11px; color:#aaa;">
                        Section: ${t.section || 'TASK'} | 
                        Priority: ${t.priority} | 
                        Status: <strong style="${t.status === 'COMPLETED' ? 'color:#2ecc71;' : 'color:#f39c12;'}">${t.status}</strong> | 
                        Due: ${t.due_date || 'No Date'}
                    </span>
                </div>
            </div>
        `).join('') || '<div style="padding:10px; color:#aaa; font-size:13px;">No tasks match filters.</div>';
    }


    //export db file form
   

async function exportDB() {
  const btn = document.getElementById("exportBtn");

    try {
        btn.innerHTML = "⏳ Exporting...";
        btn.disabled = true;

        const response = await fetch("/backup/download");

        if (!response.ok) {
            throw new Error("Download failed");
        }

        const blob = await response.blob();

        // ✅ Create download link
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement("a");

        // dynamic file name
        const fileName = "backup-" + Date.now() + ".sql";

        a.href = url;
        a.download = fileName;

        document.body.appendChild(a);
        a.click();

        // cleanup
        a.remove();
        window.URL.revokeObjectURL(url);

        btn.innerHTML = '<i class="fa-solid fa-download"></i> Export DB';
        btn.disabled = false;

    } catch (err) {
        console.error(err);
        alert("❌ Export failed");

        btn.innerHTML = '<i class="fa-solid fa-download"></i> Export DB';
        btn.disabled = false;
    }
}

