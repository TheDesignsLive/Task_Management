<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<title>Teams</title>
<link rel="icon" type="image/svg" href="/images/tms.svg">
<style>
/* ===== Body - Matching Theme ===== */
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background-color: #3C3A3A;
  overflow: hidden;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ===== Layout ===== */
.layout {
  display: flex;
  flex: 1;
  overflow: hidden;
}

.sidebar-container {
  width: 55px;
  background: #095959;
  height: 100%;
}

.main-content {
  flex: 1;
  padding: 20px;
  background: #3C3A3A;
  overflow-y: auto;
  height: 100%;
}

/* Custom Scrollbar */
.main-content::-webkit-scrollbar { width: 6px; }
.main-content::-webkit-scrollbar-track { background: #2E2D2D; }
.main-content::-webkit-scrollbar-thumb { background: #555; border-radius: 10px; }

/* ===== Sub Header ===== */
.sub-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
  padding: 0 50px;
}

.sub-header input[type="text"] {
  padding: 10px 20px;
  border: none;
  border-radius: 100px;
  background: white;
  color: #333;
  width: 300px;
  outline: none;
}

.header-buttons {
  display: flex;
  gap: 10px;
}

.header-buttons button {
  padding: 8px 18px;
  border: none;
  cursor: pointer;
  background-color: #0F8989;
  color: white;
  border-radius: 100px;
  font-weight: bold;
  font-size: 13px;
  transition: background 0.3s;
}

.header-buttons button:hover { background-color: #12a3a3; }

/* ===== Table - Dark Theme ===== */
.table-container {
  background-color: rgba(255,255,255,0.05);
  padding: 20px;
  border-radius: 8px;
  margin: 0 50px;
}

table {
  width: 100%;
  border-collapse: collapse;
  color: white;
}

table th {
  background-color: #CDF4F4;
  color: #095959;
  text-align: center;
  padding: 12px;
  font-size: 14px;
  border-bottom: 1px solid rgba(255,255,255,0.1);
}

table td {
  padding: 12px;
  text-align: center;
  border-bottom: 1px solid rgba(255,255,255,0.05);
  font-size: 13px;
}

table tr:hover td {
  background-color: rgba(255,255,255,0.02);
}

.no-records {
  text-align: center;
  color: #888;
  padding: 40px;
}

/* ===== Dialog Overlay ===== */
.dialog-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.6);
  display: none;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

/* ===== Dialog Box ===== */
.dialog-box {
  background: #fff;
  width: 380px;
  padding: 25px;
  border-radius: 8px;
  position: relative;
}
.dialog-box label {
  display: block;
  margin-bottom: 6px;   /* 🔥 space between label and input */
  font-weight:400;
}

.dialog-box input,
.dialog-box select {
  width: 100%;
  padding: 8px;
  margin-bottom: 12px;
  border: 1px solid #ccc;
  border-radius: 5px;
  box-sizing: border-box;
}

.dialog-box button {
  width: 100%;
  padding: 10px;
  background: #209595;
  color: #fff;
  border: none;
  border-radius: 5px;
  cursor: pointer;
  font-weight: bold;
}

.close-btn {
  position: absolute;
  top: 6px;
  right: 10px;
  font-size: 20px;
  cursor: pointer;
  font-weight: bold;
  color: #999;
}
.close-btn:hover { color: red; }

/* ===== Action Icons ===== */
.actions-container {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 15px;
}

.action-icon {
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  color: #aaa;
  transition: color 0.2s;
  text-decoration: none;
}
.edit-icon:hover { color: #f1c40f; }
.delete-icon:hover { color: #ff4d4d; }

/* ===== Confirmation Modal Style ===== */
.confirm-modal-content {
  background: white;
  padding: 25px;
  border-radius: 12px;
  width: 380px;
  text-align: center;
  color: #333;
  box-shadow: 0 15px 40px rgba(0,0,0,0.25);
}

.modal-buttons { 
  margin-top: 25px; 
  display: flex; 
  justify-content: center; 
  gap: 15px; 
}

.btn { 
  flex: 1; 
  height: 44px;
  border: none; 
  cursor: pointer; 
  border-radius: 8px; 
  font-size: 15px; 
  font-weight: bold; 
  display: flex; 
  align-items: center; 
  justify-content: center;
  transition: 0.2s;
  box-sizing: border-box;
}
.btn-danger { background-color: #e74c3c; color: #fff; }
.btn-danger:hover { background-color: #c0392b; }
.btn-cancel { background-color: #f1f1f1; color: #333; }
.btn-cancel:hover { background-color: #e2e2e2; }
.btn-success { background-color: #0F8989; color: #fff; } 
.btn-success:hover { background-color: #0c7575; }

</style>
</head>

<body>

<%- include('navbar') %>

<div class="layout">

  <div class="sidebar-container">
    <%- include('sidebar') %>
  </div>

  <div class="main-content">

    <div class="sub-header">
      <input type="text" placeholder="Search department..." id="searchTeam">
      <div class="header-buttons">
        <button onclick="openTeamDialog()">Add Department</button>
          <button onclick="location.href='/view-roles'">Roles Panel</button>
        <button onclick="location.href='/view_member'">Members Panel</button>
      </div>
    </div>

    <div class="table-container" id="tableContent">
      <% if (teams && teams.length > 0) { %>
        <table id="teamsTable">
          <thead>
            <tr>
              <th>ID</th>
              <th>Department Name</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>

          <tbody>
            <% teams.forEach((t, index) => { %>
             <tr class="team-row">
                <td><%= index + 1 %></td>
                <td class="team-name"><%= t.name %></td>
                <td><%= new Date(t.created_at).toLocaleDateString() %></td>

                <td>
                  <div class="actions-container">

                    <a href="javascript:void(0)" 
                       onclick="openEditTeamDialog('<%= t.id %>','<%= t.name %>')" 
                       class="action-icon edit-icon">
                      <i class="fa-solid fa-pen-to-square"></i>
                    </a>

                    <a href="javascript:void(0)" onclick="openDeleteTeamPopup('<%= t.id %>', '<%= t.name %>')" class="action-icon delete-icon">
                      <i class="fa-solid fa-trash"></i>
                    </a>

                  </div>
                </td>

              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <div class="no-records">No teams found</div>
      <% } %>
    </div>

  </div>
</div>

<div class="dialog-overlay" id="teamDialog">
  <div class="dialog-box">
    <span class="close-btn" onclick="closeTeamDialog()">✖</span>
    <h3 style="margin-top:0; text-align: center;">Add Department</h3>
    <form id="addTeamForm">
      <label>Department Name</label>
      <input type="text" name="name" placeholder="Enter department name" required>

      <button type="submit">Create Department</button>
    </form>
  </div>
</div>

<div class="dialog-overlay" id="editTeamDialog">
  <div class="dialog-box">
    <span class="close-btn" onclick="closeEditTeamDialog()">✖</span>
    <h3 style="margin-top:0; text-align: center;">Edit Department</h3>
    <form id="editTeamForm">
      <label>Department Name</label>
      <input type="text" name="name" id="edit_team_name" required>

      <button type="submit">Update Department</button>
    </form>
  </div>
</div>

<div class="dialog-overlay" id="deleteTeamModal">
  <div class="confirm-modal-content">
    <i class="fa-solid fa-triangle-exclamation" style="font-size: 40px; color: #e74c3c; margin-bottom: 10px;"></i>
    <h3 style="margin-top:0;">Are you sure?</h3>
    <p id="deleteTeamMessage"></p>
    <div class="modal-buttons">
        <button id="confirmDeleteTeamBtn" class="btn btn-danger">Yes</button>
        <button onclick="closeDeleteTeamPopup()" class="btn btn-cancel">Cancel</button>
    </div>
  </div>
</div>

<div class="dialog-overlay" id="customAlertModal">
  <div class="confirm-modal-content">
    <i id="customAlertIcon" class="fa-solid fa-circle-check" style="font-size: 40px; margin-bottom: 10px;"></i>
    <h3 id="customAlertTitle" style="margin-top:0;">Message</h3>
    <p id="customAlertMessage" style="color: #555; font-size: 15px; margin-bottom: 25px;"></p>
    <div class="modal-buttons">
        <button id="customAlertBtn" class="btn btn-success" style="width: 100%;">Okay</button>
    </div>
  </div>
</div>

<script>
let isProcessingAjax = false;
let deleteTeamId = null;

// ================= ZERO RELOAD REFRESH FUNCTION =================
async function refreshTable() {
    try {
        const response = await fetch(window.location.href);
        const html = await response.text();
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, 'text/html');
        const newTable = doc.getElementById('tableContent').innerHTML;
        document.getElementById('tableContent').innerHTML = newTable;
    } catch (err) { console.error(err); }
}

// ================= ALERT =================
function showAlertDialog(title, message, isSuccess) {
  document.getElementById("customAlertTitle").innerText = title;
  document.getElementById("customAlertMessage").innerText = message;
  
  const icon = document.getElementById("customAlertIcon");
  const btn = document.getElementById("customAlertBtn");

  if(isSuccess) {
      icon.className = "fa-solid fa-circle-check";
      icon.style.color = "#2ecc71";
      btn.className = "btn btn-success";
  } else {
      icon.className = "fa-solid fa-triangle-exclamation";
      icon.style.color = "#e74c3c";
      btn.className = "btn btn-danger";
  }
  
  document.getElementById("customAlertModal").style.display = "flex";
}
document.getElementById("customAlertBtn").addEventListener("click", function() {
  document.getElementById("customAlertModal").style.display = "none";
  isProcessingAjax = false;
});

// ================= SEARCH =================
document.getElementById('searchTeam').addEventListener('input', function() {
  const filter = this.value.toLowerCase();
  const rows = document.querySelectorAll('.team-row');
  rows.forEach(row => {
    const nameText = row.querySelector('.team-name').textContent.trim().toLowerCase();
    row.style.display = nameText.startsWith(filter) ? "" : "none";
  });
});

// ===== Dialogs =====
function openTeamDialog() { document.getElementById("teamDialog").style.display = "flex"; 


  // ✅ ADD THIS LINE
  document.querySelector('#teamDialog input[name="name"]').focus();
}
function closeTeamDialog() { document.getElementById("teamDialog").style.display = "none"; }

function openEditTeamDialog(id, name) {
  document.getElementById("editTeamDialog").style.display = "flex";
  document.getElementById("edit_team_name").value = name;
  document.getElementById("editTeamForm").dataset.action = "/edit-team/" + id;
}
function closeEditTeamDialog() { document.getElementById("editTeamDialog").style.display = "none"; }

function openDeleteTeamPopup(id, name) {
  deleteTeamId = id;
  document.getElementById("deleteTeamMessage").innerHTML = `Permanently delete the <b>${name}</b> Department?`;
  document.getElementById("deleteTeamModal").style.display = "flex";
}
function closeDeleteTeamPopup() { document.getElementById("deleteTeamModal").style.display = "none"; }

// ===== ADD TEAM =====
document.getElementById('addTeamForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const data = { name: this.name.value };
    
    isProcessingAjax = true;
    try {
        const response = await fetch('/add-team', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        const resData = await response.json();
        if(resData.success) {
            closeTeamDialog();
            this.reset();
            showAlertDialog("Success!", resData.message, true);
        } else {
            isProcessingAjax = false;
            showAlertDialog("Error", resData.message, false);
        }
    } catch(err) { isProcessingAjax = false; showAlertDialog("Error", "Server Error", false); }
});

// ===== EDIT TEAM =====
document.getElementById('editTeamForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const data = { name: this.name.value };
    
    isProcessingAjax = true;
    try {
        const response = await fetch(this.dataset.action, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        const resData = await response.json();
        if(resData.success) {
            closeEditTeamDialog();
            showAlertDialog("Updated!", resData.message, true);
        } else {
            isProcessingAjax = false;
            showAlertDialog("Error", resData.message, false);
        }
    } catch(err) { isProcessingAjax = false; showAlertDialog("Error", "Server Error", false); }
});

// ===== DELETE TEAM =====
document.getElementById("confirmDeleteTeamBtn").addEventListener('click', async () => {
    if(deleteTeamId) {
        isProcessingAjax = true;
        try {
            const response = await fetch('/delete-team/' + deleteTeamId);
            const resData = await response.json();
            closeDeleteTeamPopup();
            if(resData.success) showAlertDialog("Deleted!", resData.message, true);
            else { isProcessingAjax = false; showAlertDialog("Error", resData.message, false); }
        } catch(err) { isProcessingAjax = false; showAlertDialog("Error", "Server Error", false); }
    }
});

// DIALOG CLICK BACKGROUND (only close delete & alert)
window.onclick = function(event) {
  if(event.target.className === 'dialog-overlay') {
      if(event.target.id === 'deleteTeamModal') event.target.style.display="none";
      if(event.target.id === 'customAlertModal') event.target.style.display="none";
  }
}

</script>

<script src="/socket.io/socket.io.js"></script>
<script>
    const socket = io();
    socket.on('update_teams', () => {
        refreshTable();
    });
</script>

</body>
</html>