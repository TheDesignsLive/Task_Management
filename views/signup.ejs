<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<link rel="manifest" href="/manifest.json">
<meta name="theme-color" content="#095959">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<title>Auth | TMS Workspace</title>
<link rel="icon" type="image/svg" href="/images/tms.svg">
<style>
/* =========================================
   GLOBAL RESET & SCROLLING
   ========================================= */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
}

html {
    scroll-behavior: smooth;
}

body {
    background: #0f172a; 
    color: #f8fafc;
    overflow-x: hidden;
}

/* =========================================
   BACKGROUND ANIMATIONS & GRAPHICS
   ========================================= */
.bg-graphics {
    position: fixed; 
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
}

.bg-mesh {
    position: absolute;
    width: 100%;
    height: 100%;
    background-image: 
        radial-gradient(at 0% 0%, rgba(20, 184, 166, 0.12) 0px, transparent 50%),
        radial-gradient(at 100% 0%, rgba(2, 132, 199, 0.12) 0px, transparent 50%),
        radial-gradient(at 100% 100%, rgba(15, 118, 110, 0.15) 0px, transparent 50%),
        radial-gradient(at 0% 100%, rgba(3, 105, 161, 0.12) 0px, transparent 50%);
}

.shape {
    position: absolute;
    filter: blur(90px);
    border-radius: 50%;
    opacity: 0.5;
    animation: drift 20s infinite alternate ease-in-out;
}
.shape-1 { top: -10%; left: -10%; width: 45vw; height: 45vw; background: #2dd4bf; }
.shape-2 { bottom: -20%; right: -10%; width: 55vw; height: 55vw; background: #0ea5e9; animation-delay: -5s; }
.shape-3 { top: 30%; left: 50%; width: 35vw; height: 35vw; background: #10b981; opacity: 0.3; animation-delay: -10s; }
.shape-4 { top: 70%; left: -5%; width: 25vw; height: 25vw; background: #6366f1; opacity: 0.4; animation-delay: -7s; }

@keyframes drift {
    0% { transform: scale(1) translate(0, 0) rotate(0deg); }
    50% { transform: scale(1.2) translate(8vw, 8vh) rotate(180deg); }
    100% { transform: scale(0.9) translate(-8vw, -8vh) rotate(360deg); }
}

/* Floating Elements for Hero */
.floating-element {
    position: absolute;
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 12px 20px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    gap: 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.2);
    animation: float 6s ease-in-out infinite;
    z-index: 1;
}

.float-1 { top: 20vh; left: 8vw; animation-delay: 0s; }
.float-2 { top: 65vh; right: 8vw; animation-delay: 2s; }
.float-3 { bottom: 12vh; left: 12vw; animation-delay: 4s; }

.floating-element i { font-size: 24px; }
.floating-element div { display: flex; flex-direction: column; }
.floating-element span.title { font-weight: 600; font-size: 14px; }
.floating-element span.desc { font-size: 12px; color: #94a3b8; }

@keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
}

/* =========================================
   NAVIGATION BAR
   ========================================= */
nav {
    position: fixed;
    top: 0;
    width: 100%;
    padding: 20px 50px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 100;
    background: rgba(15, 23, 42, 0.5);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    transition: all 0.3s ease;
}

.nav-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 24px;
    font-weight: 800;
    color: #fff;
    text-decoration: none;
    letter-spacing: 1px;
}
.nav-brand img { width: 35px; border-radius: 50%; }

.nav-links {
    display: flex;
    gap: 30px;
}
.nav-links a {
    color: #cbd5e1;
    text-decoration: none;
    font-weight: 500;
    font-size: 15px;
    transition: color 0.2s;
}
.nav-links a:hover { color: #2dd4bf; }

/* =========================================
   SCROLL REVEAL ANIMATIONS
   ========================================= */
.reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.8s ease-out;
}
.reveal.active {
    opacity: 1;
    transform: translateY(0);
}

/* =========================================
   PAGE SECTIONS
   ========================================= */
.hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 100px 20px 40px;
    z-index: 10;
}

.hero-content {
    text-align: center;
    margin-bottom: 40px;
    animation: slideDown 1s ease-out forwards;
}

.hero-content h1 {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -1px;
    background: linear-gradient(to right, #2dd4bf, #0ea5e9);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 15px;
}

.hero-content p {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: #cbd5e1;
    font-weight: 300;
    max-width: 600px;
    margin: 0 auto;
}

@keyframes slideDown {
    from { opacity: 0; transform: translateY(-30px); }
    to { opacity: 1; transform: translateY(0); }
}

.scroll-indicator {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    color: #94a3b8;
    font-size: 14px;
    cursor: pointer;
    text-decoration: none;
    animation: bounce 2s infinite;
    z-index: 10;
}

.scroll-indicator i { margin-top: 8px; font-size: 20px; }

@keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateY(0) translateX(-50%); }
    40% { transform: translateY(-10px) translateX(-50%); }
    60% { transform: translateY(-5px) translateX(-50%); }
}

/* --- STATS SECTION --- */
.stats-section {
    position: relative;
    padding: 60px 20px;
    background: rgba(255, 255, 255, 0.02);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    z-index: 10;
    display: flex;
    justify-content: center;
    gap: 8vw;
    flex-wrap: wrap;
    backdrop-filter: blur(5px);
}

.stat-box { text-align: center; }
.stat-box h2 { font-size: 3rem; color: #2dd4bf; margin-bottom: 5px; font-weight: 800; }
.stat-box p { color: #94a3b8; font-size: 1rem; font-weight: 500; text-transform: uppercase; letter-spacing: 1px; }


/* --- FEATURES SECTION --- */
.features-section {
    position: relative;
    padding: 120px 20px;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
}

.section-title { text-align: center; margin-bottom: 60px; }
.section-title h2 { font-size: 2.5rem; color: #f8fafc; margin-bottom: 15px; }
.section-title p { color: #94a3b8; font-size: 1.1rem; max-width: 600px; margin: 0 auto;}

.features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 30px;
    max-width: 1200px;
    width: 100%;
}

.feature-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 40px 30px;
    border-radius: 20px;
    text-align: center;
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), background 0.3s;
    backdrop-filter: blur(10px);
}

.feature-card:hover {
    transform: translateY(-15px);
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(45, 212, 191, 0.4);
    box-shadow: 0 15px 30px rgba(0,0,0,0.2);
}

.feature-icon {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, rgba(20, 184, 166, 0.2), rgba(14, 165, 233, 0.2));
    color: #2dd4bf;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32px;
    margin: 0 auto 25px;
    transition: transform 0.3s;
}

.feature-card:hover .feature-icon { transform: scale(1.1) rotate(5deg); color: #fff; }
.feature-card h3 { font-size: 1.3rem; margin-bottom: 15px; color: #f8fafc; }
.feature-card p { color: #94a3b8; line-height: 1.6; }


/* --- WORKFLOW SECTION --- */
.workflow-section {
    position: relative;
    padding: 100px 20px;
    z-index: 10;
    background: rgba(0, 0, 0, 0.2);
    display: flex;
    flex-direction: column;
    align-items: center;
}

.workflow-container {
    max-width: 1000px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 40px;
    position: relative;
}

/* Vertical line connecting steps */
.workflow-container::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50px;
    width: 2px;
    background: linear-gradient(to bottom, #14b8a6, #0ea5e9, transparent);
    z-index: 0;
}

.workflow-step {
    display: flex;
    align-items: center;
    gap: 30px;
    position: relative;
    z-index: 1;
}

.step-number {
    width: 60px;
    height: 60px;
    background: #0f172a;
    border: 2px solid #14b8a6;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    font-weight: bold;
    color: #2dd4bf;
    box-shadow: 0 0 20px rgba(20, 184, 166, 0.3);
    margin-left: 20px; /* Aligns with the line */
}

.step-content {
    background: rgba(255, 255, 255, 0.03);
    padding: 25px;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    flex: 1;
}

.step-content h3 { color: #fff; font-size: 1.4rem; margin-bottom: 10px; }
.step-content p { color: #94a3b8; line-height: 1.6; }

/* --- FOOTER --- */
footer {
    position: relative;
    z-index: 10;
    background: #090e17;
    padding: 60px 20px 20px;
    text-align: center;
    border-top: 1px solid rgba(255,255,255,0.05);
}
.footer-content { max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 40px; margin-bottom: 40px; text-align: left; }
.footer-col h4 { color: #fff; margin-bottom: 20px; font-size: 1.2rem; }
.footer-col p, .footer-col a { color: #94a3b8; text-decoration: none; display: block; margin-bottom: 10px; transition: 0.2s; }
.footer-col a:hover { color: #2dd4bf; }
.footer-bottom { color: #64748b; font-size: 14px; padding-top: 20px; border-top: 1px solid rgba(255,255,255,0.05); }


/* =========================================
   ORIGINAL AUTH CONTAINER (UNCHANGED)
   ========================================= */
.auth-wrapper {
    animation: fadeIn 1.2s ease-out forwards;
}

@keyframes fadeIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
}

.container{
    width:380px;
    background:#fff;
    border-radius:12px;
    padding:25px;
    box-shadow:0 20px 50px rgba(0,0,0,0.4);
    position: relative;
    z-index: 20;
    color: #333; 
}

.logo-container {
    text-align: center;
    margin-bottom: 20px;
    user-select: none;
    pointer-events: none;
}

.logo-container img {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: 50%;
    border: 3px solid #14b8a6;
    pointer-events: auto;
}

.tabs{
    display:flex;
    position:relative;
    border-bottom:2px solid #e5e5e5;
    margin-bottom:20px;
}

.tab{
    flex:1;
    text-align:center;
    padding:10px;
    cursor:pointer;
    font-weight:bold;
    color:#666;
}

.tab.active{
    color:#0f766e;
}

.underline{
    position:absolute;
    bottom:-2px;
    left:0;
    width:50%;
    height:3px;
    background:#14b8a6;
    transition:0.3s;
}

.form{
    display:none;
}

.form.active{
    display:block;
}

.input-group{
    margin-bottom:15px;
    position: relative;
}

.input-group label {
    display: block;
    margin-bottom: 5px;
    font-size: 14px;
    font-weight: bold;
    color: #333;
}

.input-group input,
.input-group select{
    width:100%;
    padding:10px;
    border-radius:6px;
    border:1px solid #ccc;
    outline:none;
    color: #333;
    background: #fff;
}

.input-group input:focus,
.input-group select:focus{
    border-color:#14b8a6;
    box-shadow:0 0 5px rgba(20,184,166,0.4);
}

.error-msg {
    color: #ff4d4d;
    font-size: 11px;
    margin-top: 4px;
    display: none;
    line-height: 1.3;
}

button[type="submit"], .next-btn {
    width:100%;
    padding:11px;
    border:none;
    border-radius:6px;
    background:#14b8a6;
    color:#fff;
    font-size:15px;
    cursor:pointer;
    transition:0.3s;
}

button[type="submit"]:hover, .next-btn:hover{
    background:#0f766e;
}

.input-group button[type="button"]:not(.next-btn) {
    width:100%;
    padding:11px;
    border:none;
    border-radius:6px;
    background:#e2e8f0;
    color:#475569;
    font-size:15px;
    cursor:pointer;
    transition:0.3s;
}

.input-group button[type="button"]:not(.next-btn):hover {
    background:#cbd5e1;
}

.forgot-password {
    display: block;
    text-align: center;
    margin-bottom: -5px;
    margin-top: 16px;
    font-size: 15px;
    color: #0f766e;
    text-decoration: none;
    transition: color 0.3s;
}

.forgot-password:hover {
    color: #065f46;
}

.form-step {
    display: none;
}

.form-step.active {
    display: block;
}

#signupForm h2 {
    text-align: center;
    margin-bottom: 8px;
    color: #0f766e;
}

#signupForm .tagline {
    text-align: center;
    margin-bottom: 20px;
    font-size: 14px;
    color: #555;
}

#signupForm .form-step p {
    margin-bottom: 10px;
    color: #555;
    font-size: 14px;
    text-align: center;
}

/* === DIALOG MODAL STYLES === */
.dialog-overlay {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.65); backdrop-filter: blur(4px);
    display: none; justify-content: center; align-items: center; z-index: 9999;
}
.modal-content {
    background: #fff; width: 340px; padding: 25px; border-radius: 12px;
    text-align: center; box-shadow: 0 15px 40px rgba(0,0,0,0.25);
    color: #333;
}
.modal-buttons { margin-top: 20px; display: flex; justify-content: center; }
.btn { 
    flex: 1; height: 44px; border: none; cursor: pointer; border-radius: 8px; 
    font-size: 15px; font-weight: bold; display: flex; align-items: center; 
    justify-content: center; transition: 0.2s;
}
.btn-success { background-color: #14b8a6; color: #fff; } 
.btn-success:hover { background-color: #0f766e; }
.btn-danger { background-color: #d9534f; color: #fff; }

/* Responsive fixing for smaller screens */
@media (max-width: 1024px) {
    .floating-element { display: none; }
}
@media (max-width: 768px) {
    .workflow-container::before { left: 30px; }
    .step-number { margin-left: 0; width: 50px; height: 50px; font-size: 20px; }
    nav { padding: 15px 20px; }
    .nav-links { display: none; /* Hide links on mobile for simplicity */ }
}
</style>
</head>

<body>

<nav id="navbar">
    <a href="#" class="nav-brand">
        <img src="/images/tms.svg" alt="TMS"> TMS Workspace
    </a>
    <div class="nav-links">
        <a href="#features">Features</a>
        <a href="#workflow">How it Works</a>
        <a href="#auth">Sign In</a>
    </div>
</nav>

<div class="bg-graphics">
    <div class="bg-mesh"></div>
    <div class="shape shape-1"></div>
    <div class="shape shape-2"></div>
    <div class="shape shape-3"></div>
    <div class="shape shape-4"></div>
</div>

<div class="floating-element float-1">
    <i class="fa-solid fa-bolt" style="color: #fcd34d;"></i>
    <div>
        <span class="title">Real-time Sync</span>
        <span class="desc">Updates across all devices</span>
    </div>
</div>

<div class="floating-element float-2">
    <i class="fa-solid fa-users" style="color: #60a5fa;"></i>
    <div>
        <span class="title">Team Collaboration</span>
        <span class="desc">Work together seamlessly</span>
    </div>
</div>

<div class="floating-element float-3">
    <i class="fa-solid fa-shield-halved" style="color: #4ade80;"></i>
    <div>
        <span class="title">Bank-grade Security</span>
        <span class="desc">Your data is protected</span>
    </div>
</div>

<section class="hero-section" id="auth">
    
    <div class="hero-content">
        <h1>Master Your Workflow</h1>
        <p>The intelligent workspace that adapts to how your team works. Organize, collaborate, and execute faster.</p>
    </div>

    <div class="auth-wrapper">
        <div class="container">
            <div class="logo-container">
                <img src="/images/tms_logo.jpeg" alt="TMS Logo">
            </div>

            <div class="tabs">
                <div class="tab active" onclick="showTab(0)">Login</div>
                <div class="tab" onclick="showTab(1)">Signup</div>
                <div class="underline" id="underline"></div>
            </div>

            <form class="form active" id="loginForm">
                <div class="input-group">
                    <select id="loginType">
                        <option value="user">Login as User</option>
                        <option value="admin">Login as Admin</option>
                    </select>
                </div>

                <div class="input-group">
                    <input type="email" id="loginEmail" placeholder="Email">
                </div>

                <div class="input-group" style="position:relative;">
                    <input type="password" id="loginPassword" placeholder="Password" name="password" required>
                    <i class="fa-solid fa-eye-slash" id="toggleLoginPassword"
                       style="position:absolute; right:12px; top:50%; transform:translateY(-50%);
                       cursor:pointer; color:#999;"></i>
                </div>

                <button type="submit">Login</button>
                <a href="/forgot-password" class="forgot-password">Forgot Password?</a>
            </form>

            <form class="form" id="signupForm">
                <h2>Create Account</h2>
                <p class="tagline">Sign up to manage your tasks efficiently</p>

                <div class="form-step step-1 active">
                    <div class="input-group">
                        <input type="text" id="fullName" placeholder="Full Name" required>
                    </div>
                    <div class="input-group">
                        <input type="email" id="signupEmail" placeholder="Email" required>
                    </div>
                    <button type="button" class="next-btn" onclick="nextStep(1)">Next</button>
                </div>

                <div class="form-step step-2">
                    <p>Enter the verification code sent to your email</p>
                    <div class="input-group">
                        <input type="text" id="verificationCode" placeholder="Verification Code" required>
                    </div>
                    <div class="input-group" style="display:flex; gap:10px;">
                        <button type="button" onclick="prevStep(2)">Back</button>
                        <button type="button" class="next-btn" onclick="nextStep(2)">Verify</button>
                    </div>
                </div>

                <div class="form-step step-3">
                    <div class="input-group">
                        <input type="text" id="companyName" placeholder="Company Name" required>
                    </div>

                    <div class="input-group">
                        <input type="text" id="phone" placeholder="Phone Number" maxlength="10" oninput="this.value = this.value.replace(/[^0-9]/g, '');">
                        <div id="phoneError" class="error-msg">Please enter a valid 10-digit phone number.</div>
                    </div>

                    <div class="input-group" style="position:relative;">
                        <input type="password" id="signupPassword" placeholder="Password" required>
                        <i class="fa-solid fa-eye-slash" id="toggleSignupPassword"
                           style="position:absolute; right:12px; top:50%; transform:translateY(-50%); cursor:pointer; color:#999;"></i>
                        <div id="passError" class="error-msg">Password must be at least 8 characters with 1 uppercase, 1 lowercase, and 1 number.</div>
                    </div>

                    <div class="input-group" style="position:relative;">
                        <input type="password" id="confirmPassword" placeholder="Confirm Password" required>
                        <i class="fa-solid fa-eye-slash" id="toggleConfirmPassword"
                           style="position:absolute; right:12px; top:50%; transform:translateY(-50%); cursor:pointer; color:#999;"></i>
                        <div id="confirmError" class="error-msg">Passwords do not match. Please try again.</div>
                    </div>

                    <div class="input-group">
                        <label for="profilePic" style="font-weight:normal; font-size:13px; color:#666;">Profile Picture (Optional)</label>
                        <input type="file" id="profilePic" accept="image/*">
                    </div>

                    <div class="input-group" style="display:flex; gap:10px;">
                        <button type="button" onclick="prevStep(3)">Back</button>
                        <button type="submit">Create Account</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
    <a href="#stats" class="scroll-indicator reveal">
        Scroll to Explore
        <i class="fa-solid fa-chevron-down"></i>
    </a>
</section>

<section class="stats-section" id="stats">
    <div class="stat-box reveal">
        <h2>10k+</h2>
        <p>Active Teams</p>
    </div>
    <div class="stat-box reveal">
        <h2>2M+</h2>
        <p>Tasks Completed</p>
    </div>
    <div class="stat-box reveal">
        <h2>99.9%</h2>
        <p>Uptime Guarantee</p>
    </div>
</section>

<section class="features-section" id="features">
    <div class="section-title reveal">
        <h2>Why Choose TMS?</h2>
        <p>Everything you need to manage projects, track progress, and collaborate with your team in one unified workspace.</p>
    </div>

