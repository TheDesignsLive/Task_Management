<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Home</title>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<style>
  /* ===== PREVENT FULL PAGE SCROLL ===== */
  html, body {
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    font-family: Arial, sans-serif;
    background-color: #3C3A3A;
  }

  .layout {
    display: flex;
    height: calc(100% - 60px);
  }

  .sidebar-container {
    width: 55px;
  }

  .main-content {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .sub-header {
    display: flex;
    background-color: #CDF4F4;
    padding: 6px;
    gap: 10px;
    align-items: center;
    font-size: 14px;
  }

  .sub-header .task { flex: 4; padding: 4px; text-align: center; border-radius: 5px; background-color: #CDF4F4; }
  .sub-header .change,
  .sub-header .update { flex: 1.5; padding: 4px; text-align: center; border-radius: 5px; background-color: #CDF4F4; }
  .sub-header .other-task { flex: 2; padding: 4px; text-align: center; border-radius: 5px; background-color: #CDF4F4; }

  /* ===== CONTENT WRAPPER ===== */
  .content-wrapper {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* ===== TASK SECTION ===== */
  .task-container {
    flex: 1;
    display: flex;
    overflow: hidden;
  }

  .task-box {
    padding: 10px;
    overflow-y: auto;
  }

  .task-main { flex: 4; }
  .task-change { flex: 1.5; }
  .task-update { flex: 1.5; }
  .task-other { flex: 2; }

  .vertical-line {
    width: 1.5px;
    background-color: #7C7B7B;
    opacity: 0.8;
  }

  /* ===== COMPLETED SECTION ===== */
  .completed-header {
    margin-left: 10px;
    margin-right: 10px;
    border-radius: 100px;
    background-color: #0F8989;
    padding: 8px 20px;
    font-weight: bold;
    color: white;
    font-size: 14px;
  }

  .completed-section {
    height: 150px;
    overflow-y: auto;
    padding: 10px;
    background-color: #2E2D2D;
    color: white;
  }

  /* ===== TASK ITEM ===== */
  .task-item {
    font-size: 13px;
    padding: 6px;
    margin: 6px 0;
    background-color: #444;
    color: #fff;
    border-radius: 4px;
    cursor: pointer;
    transition: background 0.2s;
    overflow: visible; 
    position: relative;
  }

  .task-item:hover {
    background-color: #555;
  }

  .completed-task {
    opacity: 0.6;
    cursor: default;
  }

  .task-checkbox {
    width: 12px;
    height: 12px;
    appearance: none;
    border: 2px solid white; 
    border-radius: 3px;
    background: transparent;
    cursor: pointer;
    position: relative;
    flex-shrink: 0;  
  }

  .task-checkbox:checked::after {
    content: "✔";                
    position: absolute;
    top: 0;
    left: 1px;
    font-size: 7px;
    color: white;                
  }

  .priority-red { border-color: #ff4d4d; }
  .priority-yellow { border-color: #ffd633; }
  .priority-blue { border-color: #4da6ff; }
     

     
      .info-icon{
          width: 14px;         
        height: 14px;
        stroke: #959494;       
        flex-shrink: 0;
        margin-left: 8px;      
        vertical-align: middle;

          margin-left: auto; 

      }
      
  .task-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .task-title { flex: 1; min-width: 0; word-break: break-word; }
  .task-name { flex: 0 1 auto; font-size: 11px; opacity: 0.7; max-width: 80px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .task-date { flex: 0 0 50px; font-size: 11px; opacity: 0.8; white-space: nowrap; text-align: center; }

  /* ===== 3 DOT MENU ===== */
  .dots-btn { cursor: pointer; padding: 0 5px; color: #959494; font-size: 14px; margin-left: auto; }
  .dots-btn:hover { color: white; }

  .task-options-menu {
    display: none;
    position: absolute;
    right: 5px; top: 25px;
    background: white; color: #333;
    border-radius: 6px; box-shadow: 0 4px 15px rgba(0,0,0,0.3);
    z-index: 1000; min-width: 100px;
  }

  .task-options-menu div { padding: 8px 12px; font-size: 12px; cursor: pointer; display: flex; align-items: center; gap: 8px; }
  .task-options-menu div:hover { background-color: #f0f0f0; }

  /* ===== EDIT BOX ===== */
  .edit-box {
    display: none;
    background: #555;
    padding: 10px;
    border-radius: 4px;
    margin-top: 5px;
    flex-direction: column;
    gap: 8px;
  }

  .edit-box input, .edit-box textarea, .edit-box select {
    background: #3C3A3A; color: white; border: 1px solid #7C7B7B;
    padding: 5px; border-radius: 4px; font-size: 12px;
  }

  .edit-actions { display: flex; gap: 10px; justify-content: flex-end; }
  .save-btn { background: #0F8989; color: white; border: none; padding: 5px 12px; border-radius: 4px; cursor: pointer; }
  .cancel-btn { background: #7C7B7B; color: white; border: none; padding: 5px 12px; border-radius: 4px; cursor: pointer; }

  /* ===== DESCRIPTION DETAILS ===== */
  .task-details { display: none; padding-top: 8px; border-top: 1px solid #666; margin-top: 8px; font-size: 12px; }
  .task-desc-text { color: #ccc; line-height: 1.4; margin-bottom: 8px; }
  .task-item.expanded .task-details { display: block; }

  /* ===== CALENDAR OVERRIDE ===== */


  /* Class to show details when active */
  .task-item.expanded .task-details {
    display: block;
  }

  
  .task-date-picker {
  width: 0;
  height: 0;
  opacity: 0;
  position: absolute;
}

/* TRUE LOGO: calendar style for task-date */
.flatpickr-calendar.task-calendar {
  margin-top: 0 !important;
  width: 330px !important;
  border-radius: 16px;
  border: none;
  box-shadow: 0 12px 30px rgba(0,0,0,0.12);
  font-family: Segoe UI, sans-serif;
}



/* TRUE LOGO: FORCE FLATPICKR ALWAYS OPEN AT TOP CENTER */
.flatpickr-calendar.open {
  position: fixed !important;
  top: 190px !important;              /* 🔥 change this to move up/down */
  left: 60% !important;
     right: 20px !important; 
  transform: translateX(-50%) !important;
  bottom: auto !important;           /* 🔥 VERY IMPORTANT */
}



.flatpickr-months .flatpickr-month {
  height: 32px !important;
}

.flatpickr-weekdays {
  font-size: 10px !important;
}


.flatpickr-days {
  width: 100% !important;
}

.numInputWrapper input {
  font-size: 12px !important;
}

.past-date {
  color: #ff4d4d !important;   /* 🔴 red color */
  font-weight:500;
}

.center-calendar {
  position: fixed !important;
  top: 20% !important;          /* change this value */
  left: 60% !important;
  transform: translateX(-50%) !important;
  z-index: 10000 !important;
}

.flatpickr-calendar {
  font-size: 12px;              /* overall small text */
  width: 280px !important;      /* smaller width */
  border-radius: 12px;
}

.flatpickr-day {
  height: 30px;
  line-height: 30px;
  font-size: 12px;
}

.flatpickr-weekday {
  font-size: 11px;
}

.flatpickr-current-month {
  font-size: 13px;
}

.flatpickr-monthDropdown-months,
.numInputWrapper {
  font-size: 12px;
}


</style>
</head>

<body>
<%- include('navbar') %>

<div class="layout">
  <div class="sidebar-container">
      <%- include('sidebar') %>
  </div>

  <div class="main-content">
    <div class="sub-header">
      <div class="task">Task</div>
      <div class="change">Change</div>
      <div class="update">Update</div>
      <div class="other-task">Others</div>
    </div>

    <div class="content-wrapper">
      <div class="task-container">
        <div class="task-box task-main" id="task-section"></div>
        <div class="vertical-line"></div>
        <div class="task-box task-change" id="change-section"></div>
        <div class="vertical-line"></div>
        <div class="task-box task-update" id="update-section"></div>
        <div class="vertical-line"></div>
        <div class="task-box task-other" id="other-section"></div>
      </div>

      <div class="completed-header">Completed Tasks</div>
      <div class="completed-section" id="completed-section"></div>
    </div>
  </div>
</div>

<script>
const tasks = <%- JSON.stringify(tasks) %>;

function formatDate(dateStr) {
  if (!dateStr) return '';
  const today = new Date();
  const taskDate = new Date(dateStr);
  today.setHours(0,0,0,0);
  taskDate.setHours(0,0,0,0);

  const tomorrow = new Date(today);
  tomorrow.setDate(today.getDate() + 1);

  if (taskDate.getTime() === today.getTime()) return "Today";
  else if (taskDate.getTime() === tomorrow.getTime()) return "Tom";
  else return taskDate.toLocaleDateString('en-GB', { day: '2-digit', month: 'short' });
}

function getPriorityClass(priority) {
  if (!priority) return '';
  const p = priority.toUpperCase();
  if (p === 'HIGH') return 'priority-red';
  if (p === 'MEDIUM') return 'priority-yellow';
  if (p === 'LOW') return 'priority-blue';
  return '';
}

async function updateTaskStatus(id, status, section=null) {
  const res = await fetch('/update-task-status', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id, status, section })
  });
  return res.json();
}

function createTaskElement(task) {
  const div = document.createElement('div');
  div.className = 'task-item';
  div.dataset.id = task.id;

  if (task.status === 'COMPLETED') div.classList.add('completed-task');

  const priorityClass = getPriorityClass(task.priority);

  div.innerHTML = `
    <div class="task-row">
      <input type="checkbox" class="task-checkbox ${priorityClass}" ${task.status === 'COMPLETED' ? 'checked' : ''} />
      <div class="task-title">${task.title}</div>
      <div class="task-name">${task.assigned_by_name || ''}</div>
      
      <svg class="info-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="8" x2="12" y2="8.5"></line>
        <line x1="12" y1="11" x2="12" y2="16"></line>
      </svg>

      <div class="task-date ${isPastDate(task.due_date) && task.status !== 'COMPLETED' ? 'past-date' : ''}">
        ${formatDate(task.due_date)}
      </div>

      <div class="dots-btn">
        <i class="fa-solid fa-ellipsis-vertical"></i>
      </div>

      <div class="task-options-menu">
        <div class="edit-opt"><i class="fa-solid fa-pen"></i> Edit</div>
        <div class="delete-opt" style="color:red"><i class="fa-solid fa-trash"></i> Delete</div>
      </div>
    </div>

    <div class="edit-box">
      <input type="text" class="edit-title" value="${task.title}" placeholder="Title">
      <textarea class="edit-desc" placeholder="Description">${task.description || ''}</textarea>
      <div style="display:flex; gap:5px;">
        <select class="edit-priority">
          <option value="HIGH" ${task.priority === 'HIGH' ? 'selected' : ''}>High</option>
          <option value="MEDIUM" ${task.priority === 'MEDIUM' ? 'selected' : ''}>Medium</option>
          <option value="LOW" ${task.priority === 'LOW' ? 'selected' : ''}>Low</option>
        </select>
<input type="text" class="edit-date" placeholder="Due Date" >
      </div>
      <div class="edit-actions">
        <button class="save-btn">Save</button>
        <button class="cancel-btn">Cancel</button>
      </div>
    </div>

    <div class="task-details">
      <div class="task-desc-text">${task.description || 'No description provided.'}</div>
    </div>
  `;

  if (task.status !== 'COMPLETED') div.draggable = true;

  // Toggle Edit Box on Double Click
div.addEventListener('dblclick', () => {
  if (task.status === 'COMPLETED') return;

  const editBox = div.querySelector('.edit-box');
  editBox.style.display = 'flex';

  const dateInput = editBox.querySelector('.edit-date');

  // Destroy old flatpickr if exists
  if (dateInput._flatpickr) {
    dateInput._flatpickr.destroy();
  }

  // ✅ Get date from database (already in task object)
  let dbDate = task.due_date;

  // If date exists, set it
  if (dbDate) {
    dateInput.value = dbDate;  // format must be YYYY-MM-DD
  }

  // Initialize flatpickr with same date
  flatpickr(dateInput, {
    dateFormat: "Y-m-d",
    defaultDate: dbDate || null
  });
});
  // Dots Menu logic
  const dotsBtn = div.querySelector('.dots-btn');
  const menu = div.querySelector('.task-options-menu');
  dotsBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    document.querySelectorAll('.task-options-menu').forEach(m => m.style.display = 'none');
    menu.style.display = 'block';
  });

  div.querySelector('.edit-opt').addEventListener('click', () => {
    div.dispatchEvent(new Event('dblclick'));
    menu.style.display = 'none';
  });

  div.querySelector('.cancel-btn').addEventListener('click', (e) => {
    e.stopPropagation();
    div.querySelector('.edit-box').style.display = 'none';
  });

  div.querySelector('.save-btn').addEventListener('click', async (e) => {
    e.stopPropagation();
    const title = div.querySelector('.edit-title').value;
    const description = div.querySelector('.edit-desc').value;
    const priority = div.querySelector('.edit-priority').value;
 let due_date = div.querySelector('.edit-date').value.trim();
if (due_date === "") {
  due_date = null;
}

    const res = await fetch('/update-task-details', { // Create this endpoint in backend
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: task.id, title, description, priority, due_date })
    });
    if(res.ok) window.location.reload();
  });

  div.querySelector('.delete-opt').addEventListener('click', async () => {
  if(confirm("Delete this task?")) {

    try {
      const res = await fetch(`/tasks/delete-task/${task.id}`, {
        method: 'POST'
      });

      if (!res.ok) {
        alert("Server error");
        return;
      }

      // Skip parsing JSON (simpler)
      window.location.reload();

    } catch (error) {
      console.error("Delete error:", error);
      alert("Delete failed");
    }

  }
});

  // Info icon toggle
  div.querySelector('.info-icon').addEventListener('click', (e) => {
    e.stopPropagation();
    div.classList.toggle('expanded');
  });

  // Checkbox toggle
  div.querySelector('.task-checkbox').addEventListener('change', async (e) => {
    const status = e.target.checked ? 'COMPLETED' : 'OPEN';
    const section = e.target.checked ? 'COMPLETED' : 'TASK';
    const res = await updateTaskStatus(task.id, status, section);
    if(res.success) window.location.reload();
  });

  return div;
}

document.addEventListener('click', () => {
  document.querySelectorAll('.task-options-menu').forEach(m => m.style.display = 'none');
});

function isPastDate(dateStr) {
  if (!dateStr) return false;
  const today = new Date();
  const taskDate = new Date(dateStr);
  today.setHours(0,0,0,0);
  taskDate.setHours(0,0,0,0);
  return taskDate < today;
}

// ✅ INIT SECTIONS AND SORT ASCENDING BY DATE + PRIORITY
function initSections() {
  const sections = {
    'TASK': document.getElementById('task-section'),
    'CHANGES': document.getElementById('change-section'),
    'UPDATE': document.getElementById('update-section'),
    'OTHERS': document.getElementById('other-section'),
    'COMPLETED': document.getElementById('completed-section')
  };

  const sectionTasks = { 'TASK': [], 'CHANGES': [], 'UPDATE': [], 'OTHERS': [], 'COMPLETED': [] };

  tasks.forEach(task => {
    const targetSection = task.status === 'COMPLETED' ? 'COMPLETED' : (task.section || 'TASK');
    if (sectionTasks[targetSection]) sectionTasks[targetSection].push(task);
  });

 ['TASK','CHANGES','UPDATE','OTHERS'].forEach(sec => {

  const taskList = sectionTasks[sec];
  if (!taskList.length) return;

  const taskGroups = {};
  const noDateTasks = [];

  taskList.forEach(task => {
    const dateKey = task.due_date ? task.due_date.split('T')[0] : null;

    if (!dateKey) {
      noDateTasks.push(task);
    } else {
      if (!taskGroups[dateKey]) taskGroups[dateKey] = [];
      taskGroups[dateKey].push(task);
    }
  });

  // ✅ Sort dates ascending (YYYY-MM-DD auto sorts correctly)
  const sortedDates = Object.keys(taskGroups).sort();

  sortedDates.forEach(dateStr => {
    appendTasksToContainer(
      sections[sec],
      sortByPriority(taskGroups[dateStr])
    );
  });

  // Tasks without date at end
  appendTasksToContainer(
    sections[sec],
    sortByPriority(noDateTasks)
  );

});

  // Completed tasks
  sectionTasks['COMPLETED'].forEach(task => sections['COMPLETED'].appendChild(createTaskElement(task)));
}

// Append tasks
function appendTasksToContainer(container, taskArray) {
  taskArray.forEach(task => container.appendChild(createTaskElement(task)));
  if(taskArray.length > 0) container.appendChild(createSeparator());
}

function enableDragAndDrop() {
  const containers = { 'task-section': 'TASK', 'change-section': 'CHANGES', 'update-section': 'UPDATE' };
  Object.keys(containers).forEach(containerId => {
    const container = document.getElementById(containerId);
    container.addEventListener('dragover', e => e.preventDefault());
    container.addEventListener('drop', async (e) => {
      const draggingId = e.dataTransfer.getData('text/plain');
      if(!draggingId) return;
      await fetch('/update-task-section', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: draggingId, section: containers[containerId] })
      });
      window.location.reload();
    });
  });
}



// Separator line
function createSeparator() {
  const hr = document.createElement('div');
  hr.style.height = '1px';
  hr.style.backgroundColor = '#7C7B7B';
  hr.style.margin = '6px 0';
  hr.style.opacity = '0.5';
  return hr;
}
// ✅ PRIORITY SORT FUNCTION
function sortByPriority(tasks) {
  const priorityOrder = { 'HIGH': 1, 'MEDIUM': 2, 'LOW': 3 };
  return tasks.sort((a, b) => {
    const p1 = priorityOrder[a.priority?.toUpperCase()] || 4;
    const p2 = priorityOrder[b.priority?.toUpperCase()] || 4;
    return p1 - p2;
  });
}

// ✅ HIDDEN INPUT FOR FLATPICKR CENTER TOP
const hiddenInput = document.createElement('input');
hiddenInput.type = 'text';
hiddenInput.className = 'task-date-picker';
document.body.appendChild(hiddenInput);

let currentTaskDiv = null;

const fp = flatpickr(hiddenInput, {
  dateFormat: "Y-m-d",
  minDate: "today",
  clickOpens: false,
  appendTo: document.body,
  static: false,
  onReady: function(selectedDates, dateStr, instance) {
    const calendar = instance.calendarContainer;
    calendar.style.position = "fixed";
    calendar.style.top = "-10%";          // vertical center
    calendar.style.left = "50%";         // horizontal center
    calendar.style.transform = "translate(-50%, -50%)";
    calendar.style.margin = "0";
    calendar.style.zIndex = "10000";
    calendar.style.width = "90%";        // responsive width
    calendar.style.maxWidth = "400px";   // optional max width
  },
onOpen: function(selectedDates, dateStr, instance) {
  const calendar = instance.calendarContainer;

  calendar.classList.add("center-calendar");
},
  onChange: function(selectedDates, dateStr) {
    if (currentTaskDiv && dateStr) {
      fetch('/update-task-date', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: currentTaskDiv.dataset.id, due_date: dateStr })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) window.location.reload();
      });
    }
    currentTaskDiv = null;
  }
});

// Attach date picker to task-date
function attachDateEvents() {
  document.querySelectorAll('.task-date').forEach(div => {
    div.addEventListener('click', (e) => {
      e.stopPropagation();
      currentTaskDiv = div.closest('.task-item');
      fp.open();
    });
  });
}
// Drag support
document.addEventListener('dragstart', (e) => {
  if(e.target.classList.contains('task-item')) {
    e.dataTransfer.setData('text/plain', e.target.dataset.id);
  }
});

// INIT ON LOAD
document.addEventListener('DOMContentLoaded', ()=>{
  initSections();
  enableDragAndDrop();
  attachDateEvents(); 
});
</script>
</body>
</html>