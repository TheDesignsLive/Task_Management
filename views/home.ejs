<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Home</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<style>
  /* ===== PREVENT FULL PAGE SCROLL ===== */
  html, body {
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;   /* Prevent page scroll */
    font-family: Arial, sans-serif;
    background-color: #3C3A3A;
  }

  .layout {
    display: flex;
    height: calc(100% - 60px); /* Adjust if navbar is 60px */
  }

  .sidebar-container {
    width: 55px;
  }

  .main-content {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .sub-header {
    display: flex;
    background-color: #CDF4F4;
    padding: 6px;
    gap: 10px;
    align-items: center;
    font-size: 14px;
  }

  .sub-header .task { flex: 4; padding: 4px; text-align: center; border-radius: 5px; background-color: #CDF4F4; }
  .sub-header .change,
  .sub-header .update { flex: 1.5; padding: 4px; text-align: center; border-radius: 5px; background-color: #CDF4F4; }
  .sub-header .other-task { flex: 2; padding: 4px; text-align: center; border-radius: 5px; background-color: #CDF4F4; }

  /* ===== CONTENT WRAPPER ===== */
  .content-wrapper {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;  /* important */
  }

  /* ===== TASK SECTION ===== */
  .task-container {
    flex: 1;
    display: flex;
    overflow: hidden;   /* prevents extra scroll */
  }

  .task-box {
    padding: 10px;
    overflow-y: auto;   /* Scroll only when content overflows */
  }

  .task-main { flex: 4; }
  .task-change { flex: 1.5; }
  .task-update { flex: 1.5; }
  .task-other { flex: 2; }

  .vertical-line {
    width: 1.5px;
    background-color: #7C7B7B;
    opacity: 0.8;
  }

  /* ===== COMPLETED SECTION (Fixed height) ===== */
  .completed-header {
    margin-left: 10px;
    margin-right: 10px;
    border-radius: 100px;
    background-color: #0F8989;
    padding: 8px 20px;
    font-weight: bold;
    color: white;
    font-size: 14px;
  }

  .completed-section {
    height: 150px;
    overflow-y: auto;  /* Optional scroll for completed */
    padding: 10px;
    background-color: #2E2D2D;
    color: white;
  }

  /* ===== TASK BOX ===== */
  .task-item {
    font-size: 13px;
    padding: 6px;
    margin: 6px 0;
    background-color: #444;
    color: #fff;
    border-radius: 4px;
    cursor: pointer; /* Changed to pointer for click */
    transition: background 0.2s;
    overflow: hidden;
  }

  .task-item:hover {
    background-color: #555;
  }

  /* Completed Task */
  .completed-task {
    opacity: 0.6;
    cursor: default;
  }

  /* Checkbox base */
  .task-checkbox {
    width: 12px;
    height: 12px;
    appearance: none;
    border: 2px solid white; 
    border-radius: 3px;
    background: transparent;
    cursor: pointer;
    position: relative;
    flex-shrink: 0;  
  }

  .task-checkbox:checked::after {
    content: "✔";                
    position: absolute;
    top: 0;
    left: 1px;
    font-size: 7px;
    color: white;                
  }

  .priority-red { border-color: #ff4d4d; }
  .priority-yellow { border-color: #ffd633; }
  .priority-blue { border-color: #4da6ff; }
     
      .info-icon{
          width: 14px;         
        height: 14px;
        stroke: #959494;       
        flex-shrink: 0;
        margin-left: 8px;      
        vertical-align: middle;

          margin-left: auto; 

      }
      
  .task-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .task-title {
    flex: 1;
    min-width: 0;
    word-break: break-word;
  }

  .task-name {
    flex: 0 1 auto;
    font-size: 11px;
    opacity: 0.7;
    max-width: 80px; 
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .task-date {
     flex: 0 0 50px; 
    font-size: 11px;
    opacity: 0.8;
    white-space: nowrap;
      text-align: center; 
  }

  /* ===== EXPANDABLE DESCRIPTION ===== */
  .task-details {
    display: none; /* Hidden by default */
    padding-top: 8px;
    border-top: 1px solid #666;
    margin-top: 8px;
    font-size: 12px;
  }

  .task-desc-text {
    color: #ccc;
    line-height: 1.4;
    margin-bottom: 8px;
  }

  .edit-icon-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: #0F8989;
    color: white;
    padding: 4px 8px;
    border-radius: 4px;
    text-decoration: none;
    font-size: 11px;
  }

  .edit-icon-btn:hover {
    background: #14aaaa;
  }

  /* Class to show details when active */
  .task-item.expanded .task-details {
    display: block;
  }

  
  .task-date-picker {
  width: 0;
  height: 0;
  opacity: 0;
  position: absolute;
}

/* TRUE LOGO: calendar style for task-date */
.flatpickr-calendar.task-calendar {
  margin-top: 0 !important;
  width: 330px !important;
  border-radius: 16px;
  border: none;
  box-shadow: 0 12px 30px rgba(0,0,0,0.12);
  font-family: Segoe UI, sans-serif;
}
/*
.flatpickr-calendar.task-calendar.open {
  left: 50% !important;
  transform: translateX(-50%) !important;
}*/
/*
.center-calendar {
  position: fixed !important;
  top: 50% !important;
  left: 50% !important;
  transform: translate(-50%, -50%) !important;
  z-index: 9999 !important;
}*/

.flatpickr-calendar {
  border-radius: 16px;
  box-shadow: 0 25px 60px rgba(0,0,0,0.4);
  
}

/* TRUE LOGO: FORCE FLATPICKR ALWAYS OPEN AT TOP CENTER */
.flatpickr-calendar.open {
  position: fixed !important;
  top: 190px !important;              /* 🔥 change this to move up/down */
  left: 60% !important;
     right: 20px !important; 
  transform: translateX(-50%) !important;
  bottom: auto !important;           /* 🔥 VERY IMPORTANT */
}

/* ===== SMALL COMPACT FLATPICKR ===== */

.flatpickr-calendar {
  width: 250px !important;
  font-size: 11px !important;
}

.flatpickr-months .flatpickr-month {
  height: 32px !important;
}

.flatpickr-current-month {
  font-size: 12px !important;
}

.flatpickr-weekdays {
  font-size: 10px !important;
}

.flatpickr-day {
  height: 28px !important;
  line-height: 28px !important;
  font-size: 11px !important;
}

.flatpickr-days {
  width: 100% !important;
}

.numInputWrapper input {
  font-size: 12px !important;
}

.past-date {
  color: #ff4d4d !important;   /* 🔴 red color */
  font-weight:500;
}

</style>
</head>

<body>
<%- include('navbar') %>

<div class="layout">
  <div class="sidebar-container">
      <%- include('sidebar') %>
  </div>

  <div class="main-content">
    <div class="sub-header">
      <div class="task">Task</div>
      <div class="change">Change</div>
      <div class="update">Update</div>
      <div class="other-task">Others</div>
    </div>

    <div class="content-wrapper">
      <div class="task-container">
        <div class="task-box task-main" id="task-section"></div>
        <div class="vertical-line"></div>
        <div class="task-box task-change" id="change-section"></div>
        <div class="vertical-line"></div>
        <div class="task-box task-update" id="update-section"></div>
        <div class="vertical-line"></div>
        <div class="task-box task-other" id="other-section"></div>
      </div>

      <div class="completed-header">Completed Tasks</div>
      <div class="completed-section" id="completed-section"></div>
    </div>
  </div>
</div>

<script>
const tasks = <%- JSON.stringify(tasks) %>;

function formatDate(dateStr) {
  if (!dateStr) return '';
  const today = new Date();
  const tomorrow = new Date();
  tomorrow.setDate(today.getDate() + 1);
  const taskDate = new Date(dateStr);
  today.setHours(0,0,0,0);
  tomorrow.setHours(0,0,0,0);
  taskDate.setHours(0,0,0,0);

  if (taskDate.getTime() === today.getTime()) return "Today";
  else if (taskDate.getTime() === tomorrow.getTime()) return "Tom";
  else return taskDate.toLocaleDateString('en-GB', { day: '2-digit', month: 'short' });
}

function getPriorityClass(priority) {
  if (!priority) return '';
  if (priority.toUpperCase() === 'HIGH') return 'priority-red';
  if (priority.toUpperCase() === 'MEDIUM') return 'priority-yellow';
  if (priority.toUpperCase() === 'LOW') return 'priority-blue';
  return '';
}

async function updateTaskStatus(id, status, section=null) {
  const res = await fetch('/update-task-status', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id, status, section })
  });
  return res.json();
}

function updateTaskSection(id, section) {
  fetch('/update-task-section', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id, section })
  });
}

function createTaskElement(task) {
  const div = document.createElement('div');
  div.className = 'task-item';
  div.dataset.id = task.id;

  if (task.status === 'COMPLETED') div.classList.add('completed-task');

  const priorityClass = getPriorityClass(task.priority);

  div.innerHTML = `
    <div class="task-row">
      <input type="checkbox" class="task-checkbox ${priorityClass}" ${task.status === 'COMPLETED' ? 'checked' : ''} />
      <div class="task-title">${task.title}</div>
      <div class="task-name">${task.assigned_by_name || ''}</div>
      
      <!-- Info icon (i inside a circle) -->
      <svg class="info-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="8" x2="12" y2="8.5"></line>  <!-- dot of i -->
        <line x1="12" y1="11" x2="12" y2="16"></line>   <!-- body of i -->
      </svg>

<div class="task-date ${isPastDate(task.due_date) && task.status !== 'COMPLETED' ? 'past-date' : ''}">
  ${formatDate(task.due_date)}
</div>
 
</div>
    </div>

    <div class="task-details">
      <div class="task-desc-text">${task.description || 'No description provided.'}</div>
      <a href="/edit-task/${task.id}" class="edit-icon-btn">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
          <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
        </svg>
        Edit
      </a>
    </div>
  `;

 
      //
  if (task.status !== 'COMPLETED') div.draggable = true;

  // Toggle expand/collapse only when clicking the info icon
  const infoIcon = div.querySelector('.info-icon');
  if (infoIcon) {   // important check
    infoIcon.addEventListener('click', (e) => {
      e.stopPropagation();  // prevent parent click events
      div.classList.toggle('expanded');
    });
  }

  

  const checkbox = div.querySelector('input.task-checkbox');
  checkbox.addEventListener('change', async (e) => {
    const isChecked = e.target.checked;
    if (isChecked) {
      const res = await updateTaskStatus(task.id, 'COMPLETED', 'COMPLETED');
      if(res.success) window.location.reload();
    } else {
      const res = await updateTaskStatus(task.id, 'OPEN', 'TASK');
      if(res.success) window.location.reload();
    }
  });

  return div;
}

function createSeparator() {
  const hr = document.createElement('div');
  hr.style.height = '1px';
  hr.style.backgroundColor = '#7C7B7B';
  hr.style.margin = '6px 0';
  hr.style.opacity = '0.5';
  return hr;
}

function initSections() {
  const sections = {
    'TASK': document.getElementById('task-section'),
    'CHANGES': document.getElementById('change-section'),
    'UPDATE': document.getElementById('update-section'),
    'OTHERS': document.getElementById('other-section'),
    'COMPLETED': document.getElementById('completed-section')
  };

  const sectionTasks = { 'TASK': [], 'CHANGES': [], 'UPDATE': [], 'OTHERS': [], 'COMPLETED': [] };

  tasks.forEach(task => {
    const targetSection = task.status === 'COMPLETED' ? 'COMPLETED' : (task.section || 'TASK');
    if (sectionTasks[targetSection]) sectionTasks[targetSection].push(task);
  });

  ['TASK','CHANGES','UPDATE','OTHERS'].forEach(sec => {
    const taskList = sectionTasks[sec];
    if (!taskList.length) return;

    const taskGroups = {};
    const noDateTasks = [];
    taskList.forEach(task => {
      const dateKey = task.due_date ? new Date(task.due_date).toDateString() : null;
      if (!dateKey) noDateTasks.push(task);
      else {
        if (!taskGroups[dateKey]) taskGroups[dateKey] = [];
        taskGroups[dateKey].push(task);
      }
    });

    const sortedDates = Object.keys(taskGroups).sort((a,b)=> new Date(a)-new Date(b));
    const todayStr = new Date().toDateString();
    if (taskGroups[todayStr]) { appendTasksToContainer(sections[sec], taskGroups[todayStr]); delete taskGroups[todayStr]; }

    const tomorrow = new Date();
    tomorrow.setDate(tomorrow.getDate()+1);
    const tomorrowStr = tomorrow.toDateString();
    if (taskGroups[tomorrowStr]) { appendTasksToContainer(sections[sec], taskGroups[tomorrowStr]); delete taskGroups[tomorrowStr]; }

    sortedDates.forEach(dateStr => {
      if(dateStr !== todayStr && dateStr !== tomorrowStr) appendTasksToContainer(sections[sec], taskGroups[dateStr]);
    });
    appendTasksToContainer(sections[sec], noDateTasks);
  });

  sectionTasks['COMPLETED'].forEach(task => {
    sections['COMPLETED'].appendChild(createTaskElement(task));
  });
}

function appendTasksToContainer(container, taskArray) {
  taskArray.forEach(task => {
    container.appendChild(createTaskElement(task));
  });
  if(taskArray.length > 0) container.appendChild(createSeparator());
}

function enableDragAndDrop() {
  const containers = { 'task-section': 'TASK', 'change-section': 'CHANGES', 'update-section': 'UPDATE' };

  document.querySelectorAll('.task-item').forEach(item => {
    if(item.draggable) {
      item.addEventListener('dragstart', ()=> item.classList.add('dragging'));
      item.addEventListener('dragend', ()=> item.classList.remove('dragging'));
    }
  });

  Object.keys(containers).forEach(containerId => {
    const container = document.getElementById(containerId);
    container.addEventListener('dragover', e=> e.preventDefault());
    container.addEventListener('drop', async (e)=> {
      e.preventDefault();
      const dragging = document.querySelector('.dragging');
      if(!dragging) return;
      
      const res = await fetch('/update-task-section', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: dragging.dataset.id, section: containers[containerId] })
      });
      const data = await res.json();
      if(data.success) window.location.reload();
    });
  });
}

//


/* ================= CENTER DATE PICKER ================= */

const hiddenInput = document.createElement('input');
hiddenInput.type = 'text';
hiddenInput.className = 'task-date-picker';
document.body.appendChild(hiddenInput);

let currentTaskDiv = null;

const fp = flatpickr(hiddenInput, {
  dateFormat: "Y-m-d",
  minDate: "today",
  clickOpens: false,
  static: true,          // 🔥 important
  position: "auto",      // let us override fully

  onReady: function(selectedDates, dateStr, instance) {
    const calendar = instance.calendarContainer;
  calendar.style.position = "fixed";
  calendar.style.top = "";          // 🔥 distance from top
  calendar.style.left = "50%";
  calendar.style.transform = "translateX(-50%)"; // only horizontal center
  calendar.style.margin = "0";
  calendar.style.zIndex = "10000";
  },

  onOpen: function(selectedDates, dateStr, instance) {
    const calendar = instance.calendarContainer;

    calendar.style.top = "50%";
    calendar.style.left = "50%";
    calendar.style.transform = "translate(-50%, -50%)";
  },

  onChange: function(selectedDates, dateStr) {
    if (currentTaskDiv && dateStr) {
      fetch('/update-task-date', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id: currentTaskDiv.dataset.id,
          due_date: dateStr
        })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) window.location.reload();
      });
    }
    currentTaskDiv = null;
  }
});

function attachDateEvents() {
  document.querySelectorAll('.task-date').forEach(div => {
    div.addEventListener('click', (e) => {
      e.stopPropagation();
      currentTaskDiv = div.closest('.task-item');
      fp.open();
    });
  });
}
//

document.addEventListener('DOMContentLoaded', ()=>{
  initSections();
  enableDragAndDrop();
  attachDateEvents(); 
});

// past date text color red
/* ================= CHECK PAST DATE (ADDED) ================= */
function isPastDate(dateStr) {
  if (!dateStr) return false;

  const today = new Date();
  const taskDate = new Date(dateStr);

  today.setHours(0,0,0,0);
  taskDate.setHours(0,0,0,0);

  return taskDate < today;  // true if past
}
//
</script>
</body>
</html>
