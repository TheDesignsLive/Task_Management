<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Home</title>
<link rel="icon" type="image/svg" href="/images/tms.svg">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<style>
/* ===== CORE STYLES ===== */
html, body {
  margin: 0; padding: 0; height: 100%; overflow: hidden;
  font-family: Arial, sans-serif; background-color: #3C3A3A;
}

/* Custom Scrollbar */
::-webkit-scrollbar { width: 2px; height: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: #777; border-radius: 10px; }
::-webkit-scrollbar-thumb:hover { background: #aaa; }

/* Task Items */
.task-item {
  font-size: 13px; padding: 6px; margin: 6px 0;
  background-color: #444; color: #fff; border-radius: 4px;
  cursor: pointer; transition: background 0.2s; position: relative;
}
.task-item:hover { background-color: #555; }
.completed-task { opacity: 0.6; cursor: default; }

.task-checkbox {
  width: 12px; height: 12px; appearance: none;
  border: 2px solid white; border-radius: 3px;
  background: transparent; cursor: pointer; position: relative; flex-shrink: 0;
}
.task-checkbox:checked::after { content: "✔"; position: absolute; top: 0; left: 1px; font-size: 7px; color: white; }

.priority-red { border-color: #ff4d4d; }
.priority-yellow { border-color: #ffd633; }
.priority-blue { border-color: #4da6ff; }

/* Options Menu */
.task-options-menu {
  display: none; position: absolute; right: 5px; top: 25px;
  background: white; color: #333; border-radius: 6px;
  box-shadow: 0 4px 15px rgba(0,0,0,0.3); z-index: 1000; min-width: 100px;
}
.task-options-menu div { padding: 8px 12px; font-size: 12px; cursor: pointer; display: flex; align-items: center; gap: 8px; }
.task-options-menu div:hover { background-color: #f0f0f0; }

/* Edit Box */
.edit-box {
  display: none; background: #555; padding: 10px; border-radius: 4px;
  margin-top: 5px; flex-direction: column; gap: 8px;
}
.edit-box input, .edit-box textarea, .edit-box select {
  background: #3C3A3A; color: white; border: 1px solid #7C7B7B;
  padding: 5px; border-radius: 4px; font-size: 12px;
}

/* Modal */
.modal {
  display: none; position: fixed; z-index: 9999; left: 0; top: 0;
  width: 100%; height: 100%; background: rgba(0,0,0,0.6);
  justify-content: center; align-items: center;
}
.modal-content { background: white; padding: 25px; border-radius: 10px; width: 320px; text-align: center; }

.past-date { color: #ff4d4d !important; font-weight: 500; }
.center-calendar { position: fixed !important; top: 20% !important; left: 50% !important; transform: translateX(-50%) !important; z-index: 10000 !important; }

/* Section Backgrounds */
.task-main-bg { background: #2E2D2D; }
</style>
</head>
<body>
  <%- include('navbar') %>

  <div class="flex flex-col md:flex-row h-[calc(100vh-60px)] overflow-hidden">
    
    <div class="hidden md:block w-[55px] flex-shrink-0">
      <%- include('sidebar') %>
    </div>

    <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
      
      <div class="flex-1 overflow-x-auto overflow-y-auto md:overflow-y-hidden">
        
        <div class="flex flex-col md:flex-row h-full min-w-full md:min-w-[1350px]">
          
          <div class="flex flex-col w-full md:w-[400px] md:sticky md:left-0 z-[5] bg-[#3C3A3A] border-r border-[#7C7B7B] min-h-[300px] md:min-h-0">
            <div class="h-[30px] m-2 rounded-full bg-[#0F8989] text-white text-[12px] font-semibold flex items-center justify-center flex-shrink-0">Task</div>
            <div class="flex-1 p-[10px] overflow-y-auto task-main-bg" id="task-section"></div>
          </div>

          <div class="flex flex-col w-full md:flex-1 border-r border-[#7C7B7B] min-h-[300px] md:min-h-0">
            <div class="h-[30px] m-2 rounded-full bg-[#0F8989] text-white text-[12px] font-semibold flex items-center justify-center flex-shrink-0">Change</div>
            <div class="flex-1 p-[10px] overflow-y-auto task-main-bg" id="change-section"></div>
          </div>

          <div class="flex flex-col w-full md:flex-1 border-r border-[#7C7B7B] min-h-[300px] md:min-h-0">
            <div class="h-[30px] m-2 rounded-full bg-[#0F8989] text-white text-[12px] font-semibold flex items-center justify-center flex-shrink-0">Update</div>
            <div class="flex-1 p-[10px] overflow-y-auto task-main-bg" id="update-section"></div>
          </div>

          <div class="flex flex-col w-full md:flex-1 border-r border-[#7C7B7B] min-h-[300px] md:min-h-0">
            <div class="h-[30px] m-2 rounded-full bg-[#0F8989] text-white text-[12px] font-semibold flex items-center justify-center flex-shrink-0">Others</div>
            <div class="flex-1 p-[10px] overflow-y-auto task-main-bg" id="other-section"></div>
          </div>

          <div class="flex flex-col w-full md:w-[250px] bg-[#2E2D2D] min-h-[300px] md:min-h-0">
            <div class="h-[30px] m-2 px-3 rounded-full bg-[#0F8989] text-white text-[12px] font-semibold flex items-center justify-between flex-shrink-0">
              Completed Tasks
              <svg id="delete-completed" class="cursor-pointer hover:scale-125 transition-transform fill-[#e74c3c]" viewBox="0 0 24 24" width="20" height="20">
                <path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/>
              </svg>
            </div>
            <div class="flex-1 p-[10px] overflow-y-auto text-white" id="completed-section"></div>
          </div>

        </div>
      </div>
    </div>
  </div>

  <div id="singleDeleteModal" class="modal">
    <div class="modal-content">
      <h3 class="text-[#d32f2f] mb-2 font-bold">Delete This Task?</h3>
      <p class="text-gray-600">This task will be permanently removed.</p>
      <div class="mt-5 flex justify-between gap-4">
        <button id="confirmSingleDelete" class="flex-1 py-2 bg-[#d32f2f] text-white rounded-md">Delete</button>
        <button id="cancelSingleDelete" class="flex-1 py-2 bg-[#ccc] rounded-md">Cancel</button>
      </div>
    </div>
  </div>

  <div id="deleteModal" class="modal">
    <div class="modal-content">
      <h3 class="text-[#d32f2f] mb-2 font-bold">Delete Completed Tasks?</h3>
      <p class="text-gray-600">This action cannot be undone.</p>
      <div class="mt-5 flex justify-between gap-4">
        <button id="confirmDelete" class="flex-1 py-2 bg-[#d32f2f] text-white rounded-md">Delete</button>
        <button id="cancelDelete" class="flex-1 py-2 bg-[#ccc] rounded-md">Cancel</button>
      </div>
    </div>
  </div>

<script>
// Logic remains identical to your original code
async function refreshTasksUI() {
  const res = await fetch('/api/get-all-tasks');
  const data = await res.json();
  if(data.success) {
      currentTasks = data.tasks;
      renderAllSections(data.tasks);
  }
}

let currentTasks = <%- JSON.stringify(tasks) %>;

function formatDate(dateStr) {
  if (!dateStr) return '';
  const today = new Date();
  const taskDate = new Date(dateStr);
  today.setHours(0,0,0,0);
  taskDate.setHours(0,0,0,0);
  const tomorrow = new Date(today);
  tomorrow.setDate(today.getDate() + 1);
  if (taskDate.getTime() === today.getTime()) return "Today";
  else if (taskDate.getTime() === tomorrow.getTime()) return "Tom";
  else return taskDate.toLocaleDateString('en-GB', { day: '2-digit', month: 'short' });
}

function getPriorityClass(priority) {
  if (!priority) return '';
  const p = priority.toUpperCase();
  if (p === 'HIGH') return 'priority-red';
  if (p === 'MEDIUM') return 'priority-yellow';
  if (p === 'LOW') return 'priority-blue';
  return '';
}

async function updateTaskStatus(id, status, section=null) {
  const res = await fetch('/update-task-status', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id, status, section })
  });
  return res.json();
}

function createTaskElement(task) {
  const div = document.createElement('div');
  div.className = 'task-item';
  div.dataset.id = task.id;
  div.dataset.date = task.due_date ? task.due_date.split('T')[0] : '';
  if (task.status === 'COMPLETED') div.classList.add('completed-task');
  const priorityClass = getPriorityClass(task.priority);

  div.innerHTML = `
    <div class="flex items-center gap-[6px]">
      <input type="checkbox" class="task-checkbox ${priorityClass}" ${task.status === 'COMPLETED' ? 'checked' : ''} />
      <div class="flex-1 min-w-0 break-words">${task.title}</div>
      <div class="flex-none text-[11px] opacity-70 max-w-[80px] truncate">${task.assigned_by_name || ''}</div>
      
      ${task.description ? `
        <svg class="info-icon w-3.5 h-3.5 stroke-[#959494] hover:stroke-white ml-auto flex-shrink-0 cursor-pointer" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="8" x2="12" y2="8.5"></line>
          <line x1="12" y1="11" x2="12" y2="16"></line>
        </svg>
      ` : ''}

      <div class="task-date flex-none w-[50px] text-[11px] opacity-80 whitespace-nowrap text-center ${isPastDate(task.due_date) && task.status !== 'COMPLETED' ? 'past-date' : ''}">
        ${formatDate(task.due_date)}
      </div>

      <div class="dots-btn px-1 cursor-pointer text-[#959494] hover:text-white">
        <i class="fa-solid fa-ellipsis-vertical"></i>
      </div>

      <div class="task-options-menu">
        <div class="edit-opt"><i class="fa-solid fa-pen"></i> Edit</div>
        <div class="delete-opt" style="color:red"><i class="fa-solid fa-trash"></i> Delete</div>
      </div>
    </div>

    <div class="edit-box">
      <input type="text" class="edit-title w-full" value="${task.title}" placeholder="Title">
      <textarea class="edit-desc w-full min-h-[60px]" placeholder="Description">${task.description || ''}</textarea>
      <div class="flex gap-2">
        <select class="edit-priority flex-1">
          <option value="HIGH" ${task.priority === 'HIGH' ? 'selected' : ''}>High</option>
          <option value="MEDIUM" ${task.priority === 'MEDIUM' ? 'selected' : ''}>Medium</option>
          <option value="LOW" ${task.priority === 'LOW' ? 'selected' : ''}>Low</option>
        </select>
        <input type="text" class="edit-date flex-1" placeholder="Due Date">
      </div>
      <div class="flex gap-2 justify-end mt-2">
        <button class="save-btn bg-[#0F8989] text-white py-1 px-3 rounded text-[12px]">Save</button>
        <button class="cancel-btn bg-[#7C7B7B] text-white py-1 px-3 rounded text-[12px]">Cancel</button>
      </div>
    </div>

    <div class="task-details hidden pt-2 border-t border-[#666] mt-2 text-[12px]">
      <div class="text-[#ccc] mb-2">${task.description || 'No description provided.'}</div>
    </div>
  `;

  if (task.status !== 'COMPLETED') div.draggable = true;

  // Double Click Edit
  div.addEventListener('dblclick', () => {
    if (task.status === 'COMPLETED') return;
    const editBox = div.querySelector('.edit-box');
    editBox.style.display = 'flex';
    const dateInput = editBox.querySelector('.edit-date');
    if (dateInput._flatpickr) dateInput._flatpickr.destroy();
    flatpickr(dateInput, { dateFormat: "Y-m-d", defaultDate: task.due_date ? task.due_date.split('T')[0] : null });
  });

  // Dots Menu
  const dotsBtn = div.querySelector('.dots-btn');
  const menu = div.querySelector('.task-options-menu');
  dotsBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    document.querySelectorAll('.task-options-menu').forEach(m => m.style.display = 'none');
    menu.style.display = 'block';
  });

  div.querySelector('.edit-opt').addEventListener('click', () => {
    div.dispatchEvent(new Event('dblclick'));
    menu.style.display = 'none';
  });

  div.querySelector('.cancel-btn').addEventListener('click', (e) => {
    e.stopPropagation();
    div.querySelector('.edit-box').style.display = 'none';
  });

  div.querySelector('.save-btn').addEventListener('click', async (e) => {
    e.stopPropagation();
    const title = div.querySelector('.edit-title').value;
    const description = div.querySelector('.edit-desc').value;
    const priority = div.querySelector('.edit-priority').value;
    let due_date = div.querySelector('.edit-date').value.trim() || null;
    await fetch('/edit-task-details', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: task.id, title, description, priority, due_date })
    });
  });

  // Info Toggle
  const infoIcon = div.querySelector('.info-icon');
  if(infoIcon){
    infoIcon.addEventListener('click', (e) => {
      e.stopPropagation();
      div.querySelector('.task-details').classList.toggle('hidden');
    });
  }

  // Checkbox Toggle
  div.querySelector('.task-checkbox').addEventListener('change', async (e) => {
    const status = e.target.checked ? 'COMPLETED' : 'OPEN';
    const section = e.target.checked ? 'COMPLETED' : 'TASK';
    await updateTaskStatus(task.id, status, section);
  });

  return div;
}

document.addEventListener('click', () => {
  document.querySelectorAll('.task-options-menu').forEach(m => m.style.display = 'none');
});

function isPastDate(dateStr) {
  if (!dateStr) return false;
  const today = new Date();
  const taskDate = new Date(dateStr);
  today.setHours(0,0,0,0);
  taskDate.setHours(0,0,0,0);
  return taskDate < today;
}

function renderAllSections(taskList) {
  const sections = {
    'TASK': document.getElementById('task-section'),
    'CHANGES': document.getElementById('change-section'),
    'UPDATE': document.getElementById('update-section'),
    'OTHERS': document.getElementById('other-section'),
    'COMPLETED': document.getElementById('completed-section')
  };
  Object.values(sections).forEach(s => s.innerHTML = '');
  const sectionTasks = { 'TASK': [], 'CHANGES': [], 'UPDATE': [], 'OTHERS': [], 'COMPLETED': [] };
  
  taskList.forEach(task => {
    const targetSection = task.status === 'COMPLETED' ? 'COMPLETED' : (task.section || 'TASK');
    if (sectionTasks[targetSection]) sectionTasks[targetSection].push(task);
  });

  ['TASK','CHANGES','UPDATE','OTHERS'].forEach(sec => {
    const list = sectionTasks[sec];
    if (!list.length) return;
    const taskGroups = {};
    const noDateTasks = [];
    list.forEach(t => {
      const d = t.due_date ? t.due_date.split('T')[0] : null;
      if (!d) noDateTasks.push(t);
      else { if (!taskGroups[d]) taskGroups[d] = []; taskGroups[d].push(t); }
    });
    Object.keys(taskGroups).sort().forEach(d => {
      appendTasksToContainer(sections[sec], sortByPriority(taskGroups[d]), d);
    });
    appendTasksToContainer(sections[sec], sortByPriority(noDateTasks), null);
  });
  sectionTasks['COMPLETED'].forEach(task => sections['COMPLETED'].appendChild(createTaskElement(task)));
  attachDateEvents();
}

function appendTasksToContainer(container, taskArray, dateStr) {
  taskArray.forEach(task => container.appendChild(createTaskElement(task)));
  if(taskArray.length > 0) container.appendChild(createSeparator(dateStr));
}

function createSeparator(dateStr) {
  const hr = document.createElement('div');
  hr.className = 'date-separator';
  hr.dataset.date = dateStr || '';
  hr.style.height = '12px'; hr.style.borderBottom = '1px solid #7C7B7B'; hr.style.margin = '6px 0'; hr.style.opacity = '0.5';
  return hr;
}

function sortByPriority(tasks) {
  const order = { 'HIGH': 1, 'MEDIUM': 2, 'LOW': 3 };
  return tasks.sort((a, b) => (order[a.priority?.toUpperCase()] || 4) - (order[b.priority?.toUpperCase()] || 4));
}

// Flatpickr for date clicks
const hiddenInput = document.createElement('input');
hiddenInput.style.display = 'none';
document.body.appendChild(hiddenInput);
let currentTaskDiv = null;

const fp = flatpickr(hiddenInput, {
  dateFormat: "Y-m-d", minDate: "today", clickOpens: false,
  onOpen: (s, d, i) => i.calendarContainer.classList.add("center-calendar"),
  onChange: function(dates, dateStr) {
    if (currentTaskDiv && dateStr) {
      fetch('/update-task-date', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: currentTaskDiv.dataset.id, due_date: dateStr })
      });
    }
  }
});

function attachDateEvents() {
  document.querySelectorAll('.task-date').forEach(div => {
    div.addEventListener('click', (e) => {
      e.stopPropagation();
      currentTaskDiv = div.closest('.task-item');
      fp.open();
    });
  });
}

function enableDragAndDrop() {
  const containers = { 'task-section': 'TASK', 'change-section': 'CHANGES', 'update-section': 'UPDATE' };
  Object.keys(containers).forEach(id => {
    const el = document.getElementById(id);
    el.addEventListener('dragover', e => e.preventDefault());
    el.addEventListener('drop', async (e) => {
      e.preventDefault();
      const draggingId = e.dataTransfer.getData('text/plain');
      const targetEl = e.target.closest('.task-item, .date-separator');
      let due_date = targetEl?.dataset.date || null;
      
      await fetch('/update-task-section', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: draggingId, section: containers[id] })
      });
      if (due_date) {
        await fetch('/update-task-date', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: draggingId, due_date })
        });
      }
    });
  });
}

document.addEventListener('dragstart', (e) => {
  if(e.target.classList.contains('task-item')) e.dataTransfer.setData('text/plain', e.target.dataset.id);
});

document.addEventListener('DOMContentLoaded', ()=>{
  renderAllSections(currentTasks);
  enableDragAndDrop();
});

// Modals
document.getElementById("delete-completed").addEventListener("click", () => document.getElementById("deleteModal").style.display = "flex");
document.getElementById("cancelDelete").addEventListener("click", () => document.getElementById("deleteModal").style.display = "none");
document.getElementById("confirmDelete").addEventListener("click", async () => {
  document.getElementById("deleteModal").style.display = "none";
  await fetch('/delete-completed-tasks', { method: 'POST' });
});

let taskToDeleteId = null;
document.addEventListener("click", (e) => {
  const btn = e.target.closest(".delete-opt");
  if (btn) {
    taskToDeleteId = btn.closest(".task-item").dataset.id;
    document.getElementById("singleDeleteModal").style.display = "flex";
  }
});

document.getElementById("confirmSingleDelete").addEventListener("click", async () => {
  await fetch(`/delete-task/${taskToDeleteId}`, { method: "POST" });
  document.getElementById("singleDeleteModal").style.display = "none";
});
document.getElementById("cancelSingleDelete").addEventListener("click", () => document.getElementById("singleDeleteModal").style.display = "none");
</script>

<script src="/socket.io/socket.io.js"></script>
<script>
    const socket = io();
    socket.on('update_tasks', () => refreshTasksUI());
</script>
</body>
</html>