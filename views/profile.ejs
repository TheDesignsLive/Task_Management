<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Profile</title>

<style>
/* FILL 1 PAGE WITHOUT SCROLL */
html, body {
  height: 100%;
  margin: 0;
  padding: 0;
  font-family: 'Segoe UI', Tahoma, sans-serif;
  background: #3C3A3A;
  overflow: hidden; 
}
.layout {
  display: flex;
  height: calc(100vh - 60px); /* Height minus navbar */
}
.sidebar-container {
  width: 55px;
  height: 100%;
}
.main-content {
  flex: 1;
  padding: 20px;
  background: #f4f6f9;
  display: flex;
  justify-content: center;
  align-items: center; 
  overflow: hidden;
}
.profile-card {
  width: 420px;
  background: #fff;
  border-radius: 12px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.15);
  overflow: hidden;
  text-align: center;
}
.profile-header {
  background: linear-gradient(135deg, #095959, #00a896);
  padding: 30px 20px 45px; /* Thoda kam padding */
  color: white;
  position: relative;
}
.profile-img, .profile-letter-avatar {
  width: 100px;
  height: 100px;
  border-radius: 50%;
  border: 4px solid white;
  object-fit: cover;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  bottom: -50px; /* Image aadhi bahar */
  z-index: 10;
}
.profile-letter-avatar {
  background: #095959;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40px;
  font-weight: bold;
  color: white;
  text-transform: uppercase;
}
.profile-body {
  padding: 65px 25px 20px; /* Text ko image se niche dhakela */
}
.profile-name {
  font-size: 22px;
  font-weight: 600;
  color: #333;
  margin-bottom: 2px;
}
.profile-role {
  font-size: 13px;
  color: #888;
  margin-bottom: 15px;
}
.info-box {
  background: #f7f7f7;
  padding: 10px;
  border-radius: 6px;
  margin-bottom: 8px;
  text-align: left;
  font-size: 14px;
}
.info-box strong {
  color: #095959;
}
.profile-btn {
  margin-top: 10px;
  width: 100%;
  padding: 10px;
  border: none;
  border-radius: 6px;
  background: linear-gradient(135deg, #095959, #00a896);
  color: white;
  font-size: 14px;
  cursor: pointer;
  transition: 0.3s;
}
.profile-btn:hover {
  opacity: 0.9;
  transform: translateY(-1px);
}
.modal {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.6);
  justify-content: center;
  align-items: center;
  z-index: 1000;
}
</style>
</head>

<body>

<%- include('navbar') %>

<div class="layout">

<div class="sidebar-container">
 <%- include('sidebar') %>
</div>

<div class="main-content">

  <div class="profile-card">
    <div class="profile-header">
      <h3 style="margin:0; padding-bottom: 10px;">My Profile</h3>
      <% if (profilePic) { %>
        <img src="/images/<%= profilePic %>" class="profile-img">
      <% } else { %>
        <div class="profile-letter-avatar">
          <%= name.charAt(0) %>
        </div>
      <% } %>
    </div>

    <div class="profile-body">
      <div class="profile-name"><%= name %></div>
      <div class="profile-role"><%= role %></div>

      <div class="info-box"><strong>Company:</strong> <%= company || 'N/A' %></div>
      <div class="info-box"><strong>Email:</strong> <%= email %></div>
      <div class="info-box"><strong>Phone:</strong> <%= phone %></div>
      <div class="info-box"><strong>Account Type:</strong> <%= role %></div>
      <div class="info-box"><strong>Status:</strong> Active</div>

      <button class="profile-btn" onclick="openEdit()">Edit Profile</button>
    </div>
  </div>

</div>

</div>

<div class="modal" id="editModal">
  <div style="width:400px; background:white; border-radius:10px; padding:20px; box-shadow:0 5px 15px rgba(0,0,0,0.3);">
    <h3 style="margin-top:0;">Edit Profile</h3>
    <form action="/profile/update-profile" method="POST" enctype="multipart/form-data">
      <label style="font-size:12px; color:#666;">Full Name</label>
      <input type="text" name="name" value="<%= name %>" placeholder="Name" required style="width:100%; padding:8px; margin-bottom:10px; border:1px solid #ccc; border-radius:4px; box-sizing:border-box;">

      <label style="font-size:12px; color:#666;">Phone Number</label>
      <input type="text" name="phone" value="<%= phone %>" placeholder="Phone" style="width:100%; padding:8px; margin-bottom:10px; border:1px solid #ccc; border-radius:4px; box-sizing:border-box;">

      <% if(r=="admin"){ %>
        <label style="font-size:12px; color:#666;">Company Name</label>
        <input type="text" name="company" value="<%= company %>" placeholder="Company" style="width:100%; padding:8px; margin-bottom:10px; border:1px solid #ccc; border-radius:4px; box-sizing:border-box;">
      <% } %>

      <label style="font-size:12px; color:#666;">Profile Picture</label>
      <input type="file" name="profile_pic" style="margin-bottom:15px; width:100%;" accept="image/*">

      <div style="display:flex; gap:10px;">
        <button style="flex:1; background:#00a896; color:white; border:none; padding:10px; border-radius:4px; cursor:pointer;">Save Changes</button>
        <button type="button" onclick="closeEdit()" style="flex:1; background:#ddd; border:none; padding:10px; border-radius:4px; cursor:pointer;">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script>
function openEdit(){document.getElementById('editModal').style.display='flex';}
function closeEdit(){document.getElementById('editModal').style.display='none';}
</script>

</body>
</html>
