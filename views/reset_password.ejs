<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Reset Password</title>
<link rel="icon" type="image/svg" href="/images/tms.svg">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>
body {
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background: linear-gradient(135deg,#0f766e,#14b8a6);
    font-family: Arial, Helvetica, sans-serif;
}

.container{
    width:380px;
    background:#fff;
    border-radius:12px;
    padding:25px;
    box-shadow:0 10px 25px rgba(0,0,0,0.2);
}

.input-group {
    position: relative;
    margin-bottom:15px;
}

.input-group input {
    width:100%;
    padding:10px;
    padding-right: 40px;
    box-sizing: border-box;
    border-radius:6px;
    border:1px solid #ccc;
    outline:none;
}

/* Eye Icon */
.input-group i { 
    position: absolute; 
    right: 12px; 
    top: 50%; 
    transform: translateY(-50%); 
    cursor: pointer; 
    color: #999; 
}

/* ERROR MESSAGE SAME STYLE */
.error-msg {
    color: #ff4d4d;
    font-size: 11px;
    margin-top: 4px;
    display: none;
    line-height: 1.3;
}

input:focus {
    border-color:#14b8a6;
    box-shadow:0 0 5px rgba(20,184,166,0.4);
}

button {
    width:100%;
    padding:11px;
    border:none;
    border-radius:6px;
    background:#14b8a6;
    color:#fff;
    font-size:15px;
    cursor:pointer;
    transition:0.3s;
}

button:hover {
    background:#0f766e;
}

.input-group i { 
    position: absolute; 
    right: 12px; 
    top: 20px;   /* 🔥 FIXED instead of 50% */
    cursor: pointer; 
    color: #999; 
}
</style>
</head>

<body>

<div class="container">
    <h3>Reset Password</h3>

    <div class="input-group">
        <input type="password" id="newpass" placeholder="New Password">
        <i class="fa-solid fa-eye-slash" onclick="togglePwd('newpass', this)"></i>
        <div id="passError" class="error-msg">
            Password must be at least 8 characters with 1 uppercase, 1 lowercase, and 1 number.
        </div>
    </div>

    <div class="input-group">
        <input type="password" id="confpass" placeholder="Confirm Password">
        <i class="fa-solid fa-eye-slash" onclick="togglePwd('confpass', this)"></i>
        <div id="confirmError" class="error-msg">
            Passwords do not match. Please try again.
        </div>
    </div>

    <button onclick="resetPassword()">Reset Password</button>
</div>

<script>
function togglePwd(id, icon) {
    const input = document.getElementById(id);
    if (input.type === "password") {
        input.type = "text";
        icon.classList.replace("fa-eye-slash", "fa-eye");
    } else {
        input.type = "password";
        icon.classList.replace("fa-eye", "fa-eye-slash");
    }
}

function resetPassword() {
    const newPass = document.getElementById("newpass").value.trim();
    const confPass = document.getElementById("confpass").value.trim();

    // Hide old errors
    document.getElementById("passError").style.display = "none";
    document.getElementById("confirmError").style.display = "none";

    let hasError = false;

    // PASSWORD REGEX SAME AS SIGNUP
    const passwordRegex = /^(?=.*\d)(?=.*[a-z])(?=.*[A-Z]).{8,}$/;

    if(!passwordRegex.test(newPass)){
        document.getElementById("passError").style.display = "block";
        hasError = true;
    }

    if(newPass !== confPass){
        document.getElementById("confirmError").style.display = "block";
        hasError = true;
    }

    if(!newPass || !confPass){
        alert("Please enter and confirm your password");
        return;
    }

    if(hasError) return;

    const urlParams = new URLSearchParams(window.location.search);
    const contact = urlParams.get('contact');

    fetch('/forgot-password/reset', {
        method: 'POST',
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ contact, new_password: newPass })
    })
    .then(res => res.json())
    .then(data => {
        if(data.status === "success"){
            alert("Password reset successfully!");
            window.location.href = "/";
        } else {
            alert(data.message || "Error resetting password");
        }
    })
    .catch(err => alert("Server error"));
}
</script>

</body>
</html>