<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Notifications</title>

<style>
body{ margin:0; font-family: Arial, sans-serif; background:#3C3A3A; overflow: hidden; height: 100vh; display: flex; flex-direction: column; }
.layout{ display:flex; flex: 1; overflow: hidden; } 
.sidebar-container{ width:55px; background: #095959; height: 100%; }
.main-content{ flex:1; padding:20px; background:#f4f4f4; overflow-y: auto; height: 100%; } 
.box{ background:white; padding:20px; border-radius:8px; margin-bottom: 20px; }
table{ width:100%; border-collapse:collapse; margin-top:15px; }
th, td{ border:1px solid #ccc; padding:10px; text-align:center; }
th{ background:#CDF4F4; }
.action-btn{ padding:6px 10px; border:none; cursor:pointer; border-radius:4px; font-weight:bold; }
.accept-btn{ background:#2ecc71; color:white; }
.reject-btn{ background:#e74c3c; color:white; }
.announce-btn{ background:#095959; color:white; float: right; padding: 10px 15px; }

.avatar-circle {
  width: 40px; height: 40px; background-color: #095959; color: white;
  border-radius: 50%; display: inline-flex; align-items: center;
  justify-content: center; font-weight: bold; font-size: 16px; text-transform: uppercase;
}

.modal {
  display:none; position:fixed; inset:0; background:rgba(0,0,0,0.6);
  justify-content:center; align-items:center; z-index:1000;
}

.modal-content {
  background:white; padding:25px; border-radius:8px; width:420px; box-sizing:border-box;
}

.modal-content h3{ text-align:center; margin-top:0; margin-bottom:20px; }
.modal-content label{ display:block; margin-top:15px; font-weight:bold; text-align:left; }
.modal-content input, .modal-content select {
  width:100%; margin-top:6px; padding:8px; border:1px solid #ccc; border-radius:4px; box-sizing: border-box;
}
.modal-content textarea{
  width:100%; height:120px; resize:none; margin-top:6px; padding:8px; border:1px solid #ccc; border-radius:4px; box-sizing:border-box;
}

.announcement-card {
    border-left: 5px solid #095959; background: #fff; padding: 15px;
    margin-top: 10px; border-radius: 4px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);
}
</style>
</head>

<body>

<%- include('navbar') %>

<div class="layout">
  <div class="sidebar-container">
    <%- include('sidebar') %>
  </div>

  <div class="main-content">

    <div class="box">
      <div style="overflow: hidden;">
        <h2 style="display:inline-block;">Announcements</h2>
        <% if (session.role === 'admin' || session.control_type === 'ADMIN') { %>
            <button class="action-btn announce-btn" onclick="openAnnounce()">+ Add Announcement</button>
        <% } %>
      </div>

      <div id="announcement-list">
        <% if (announcements.length > 0) { %>
            <% announcements.forEach(a => { %>
                <div class="announcement-card">
                    <h3 style="margin:0;"><%= a.title %></h3>
                    <p style="color:#666; font-size: 12px; margin-top: 5px;">
                      By: <strong><%= a.added_by_name %></strong> | 
                      To: <strong><%= a.target_role || (a.role_id == 0 ? 'All' : 'Your Role') %></strong> |
                      <%= new Date(a.created_at).toLocaleString() %>
                    </p>
                    <p><%= a.description %></p>
                    <% if (a.attachment) { %>
                        <a href="/uploads/<%= a.attachment %>" target="_blank"
                           style="font-size:13px; color:#095959; font-weight: bold; text-decoration: none;">📎 View Attachment</a>
                    <% } %>
                </div>
            <% }) %>
        <% } else { %>
            <p style="color:#888;">No announcements found.</p>
        <% } %>
      </div>
    </div>

    <% if (session.role === 'admin') { %>
    <div class="box">
      <h2>Member Requests</h2>

      <% if (memberRequests.length > 0) { %>
        <table>
          <thead>
            <tr>
              <th>No</th>
              <th>Profile</th>
              <th>Name</th>
              <th>Email</th>
              <th>Role</th>
              <th>Requested By</th>
              <th>Date</th>
              <th>ACTION</th>
            </tr>
          </thead>
          <tbody>
            <% memberRequests.forEach((r, i) => { %>
              <tr>
                <td><%= i + 1 %></td>
                <td>
                  <% if (r.profile_pic) { %>
                    <img src="/images/<%= r.profile_pic %>" width="40" height="40"
                         style="border-radius:50%; object-fit: cover;">
                  <% } else { %>
                    <div class="avatar-circle"><%= r.name.charAt(0) %></div>
                  <% } %>
                </td>
                <td><%= r.name %></td>
                <td><%= r.email %></td>
                <td><%= r.role_name %></td>
                <td><%= r.requested_by_name %></td>
                <td><%= new Date(r.created_at).toLocaleDateString() %></td>
                <td>
                  <button class="action-btn accept-btn"
                    onclick="location.href='/approve-member/<%= r.id %>'">Accept</button>
                  <button class="action-btn reject-btn"
                    onclick="location.href='/reject-member/<%= r.id %>'">Reject</button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <p>No pending member requests.</p>
      <% } %>
    </div>
    <% } %>

  </div>
</div>

<div class="modal" id="announceModal">
    <div class="modal-content">
        <h3>Create Announcement</h3>
        <form action="/add-announcement" method="POST" enctype="multipart/form-data">
            <label>Title</label>
            <input type="text" name="title" required placeholder="Announcement Title">
            
            <label>Description</label>
            <textarea name="description" placeholder="Detail description..."></textarea>
            
            <label>Who should receive this?</label>
            <select name="role_id" required>
                <option value="0">All</option> 
                <% roles.forEach(role => { %>
                    <option value="<%= role.id %>"><%= role.role_name %></option>
                <% }) %>
            </select>
            
            <label>Attachment (Image/PDF)</label>
            <input type="file" name="attachment">
            
            <div style="display:flex; gap:10px; margin-top:20px;">
                <button type="submit" class="action-btn accept-btn" style="flex:1;">Post Now</button>
                <button type="button" class="action-btn reject-btn" style="flex:1;" onclick="closeAnnounce()">Cancel</button>
            </div>
        </form>
    </div>
</div>

<script>
function openAnnounce() { document.getElementById('announceModal').style.display='flex'; }
function closeAnnounce() { document.getElementById('announceModal').style.display='none'; }
</script>

</body>
</html>