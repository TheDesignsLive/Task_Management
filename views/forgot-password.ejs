<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Forgot Password</title>
<link rel="icon" type="image/svg" href="/images/tms.svg">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<style>
body {
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background: linear-gradient(135deg,#0f766e,#14b8a6);
    font-family: Arial, Helvetica, sans-serif;
    margin: 0;
}

.container{
    width:380px;
    background:#fff;
    border-radius:12px;
    padding:25px;
    box-shadow:0 10px 25px rgba(0,0,0,0.2);
}

.input-group {
    margin-bottom:15px;
}

.input-group input {
    width:100%;
    padding:10px;
    border-radius:6px;
    border:1px solid #ccc;
    outline:none;
}

input:focus {
    border-color:#14b8a6;
    box-shadow:0 0 5px rgba(20,184,166,0.4);
}

button {
    width:100%;
    padding:11px;
    border:none;
    border-radius:6px;
    background:#14b8a6;
    color:#fff;
    font-size:15px;
    cursor:pointer;
    transition:0.3s;
}

button:hover {
    background:#0f766e;
}

#otpBox {
    display:none;
}

#otp{
    margin-top:10px;
}

/* CUSTOM MODAL STYLES FROM NOTIFICATIONS */
.modal {
  display:none; position:fixed; inset:0; background:rgba(0,0,0,0.6);
  justify-content:center; align-items:center; z-index:1000;
}
.modal-content {
  background:white; padding:25px; border-radius:8px; width:350px; box-sizing:border-box; color: #333;
}
.modal-content h3{ text-align:center; margin-top:0; margin-bottom:10px; color: #333; }
.modal-content p { color: #555; font-size: 15px; margin-bottom: 25px; text-align: center; }

.action-btn{ padding:10px; border:none; cursor:pointer; border-radius:4px; font-weight:bold; transition: opacity 0.2s; }
.accept-btn{ background:#2ecc71; color:white; }
.reject-btn{ background:#e74c3c; color:white; }
</style>
</head>
<body>

<div class="container">
    <h3>Forgot Password</h3>

    <div class="input-group">
        <input type="text" id="contact" placeholder="Enter Email or Phone">
    </div>
    <button onclick="sendOtp()">Send OTP</button>

    <div id="otpBox">
        <div class="input-group">
            <input type="text" id="otp" placeholder="Enter OTP">
        </div>
        <button onclick="verifyOtp()">Verify OTP</button>
    </div>
</div>

<div class="modal" id="customAlertModal">
  <div class="modal-content" style="text-align: center;">
    <i id="customAlertIcon" class="fa-solid fa-circle-check" style="font-size: 40px; margin-bottom: 10px;"></i>
    <h3 id="customAlertTitle" style="margin-top:0;">Message</h3>
    <p id="customAlertMessage"></p>
    <div style="display:flex;">
        <button id="customAlertBtn" class="action-btn accept-btn" style="flex: 1; height: 44px; font-size: 15px;">Okay</button>
    </div>
  </div>
</div>

<script>
let generatedOtp = null;
let defaultContact = "jay13981398@gmail.com";

// DIALOG FUNCTION
function showAlertDialog(title, message, isSuccess) {
  document.getElementById("customAlertTitle").innerText = title;
  document.getElementById("customAlertMessage").innerText = message;
  
  const icon = document.getElementById("customAlertIcon");
  const btn = document.getElementById("customAlertBtn");

  if(isSuccess) {
      icon.className = "fa-solid fa-circle-check";
      icon.style.color = "#2ecc71";
      btn.className = "action-btn accept-btn";
  } else {
      icon.className = "fa-solid fa-triangle-exclamation";
      icon.style.color = "#e74c3c";
      btn.className = "action-btn reject-btn";
  }
  
  document.getElementById("customAlertModal").style.display = "flex";
}

document.getElementById("customAlertBtn").addEventListener("click", function() {
  document.getElementById("customAlertModal").style.display = "none";
});

async function sendOtp(){
    const contact = document.getElementById("contact").value.trim();
    if(!contact){
        showAlertDialog("Error", "Please enter email or phone", false);
        return;
    }

    const res = await fetch("/forgot-password/check", {
        method:"POST",
        headers: {"Content-Type":"application/json"},
        body: JSON.stringify({ contact })
    });

    const data = await res.json();

    if(data.status === "not_found"){
        showAlertDialog("Not Found", "Email or Phone not found in our records.", false);
        document.getElementById("contact").value = ""; 
        return;
    }

    if(data.status === "found"){
        generatedOtp = Math.floor(100000 + Math.random() * 900000); 

        // Direct open fields without alert
        document.getElementById("otpBox").style.display = "block";

        fetch("/forgot-password/send-otp", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
                contact: contact,
                otp: generatedOtp,
                sent_for: "forget_password"  
            })
        }).catch(err => console.error("Error sending OTP in background:", err));
    }
}

function verifyOtp() {
    const userOtp = document.getElementById("otp").value.trim();

    if(!userOtp){
        showAlertDialog("Error", "Please enter the OTP", false);
        return;
    }

    if(userOtp == generatedOtp){
        const contact = document.getElementById("contact").value.trim();
        window.location.href = `/reset-password?contact=${encodeURIComponent(contact)}`;
    } else {
        document.getElementById("otp").value = "";
        showAlertDialog("Invalid", "Incorrect OTP. Try again.", false);
    }
}

// Close modal if user clicks outside
window.onclick = function(event) {
    const modal = document.getElementById('customAlertModal');
    if (event.target == modal) {
        modal.style.display = "none";
    }
}
</script>

</body>
</html>