<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Assign By Me</title>

<style>
  /* ===== PREVENT FULL PAGE SCROLL ===== */
  html, body {
    margin: 0;
    padding: 0;
    height: 100%;
    overflow: hidden;
    font-family: Arial, sans-serif;
    background-color: #3C3A3A;
  }

  .layout {
    display: flex;
    height: calc(100% - 60px);
  }

  .sidebar-container {
    width: 55px;
  }

  .main-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .sub-header {
    display: flex;
    background-color: #CDF4F4;
    padding: 10px;
    gap: 10px;
    align-items: center;
    font-weight: bold;
    color: #333;
    font-size: 14px;
  }

  .sub-header .col-title { flex: 2; padding-left: 40px; }
  .sub-header .col-desc { flex: 3; padding-left: 20px; }
  .sub-header .col-assign { flex: 1.5; text-align: center; }
  .sub-header .col-date { flex: 1; text-align: right; padding-right: 20px; }

  /* ===== CONTENT WRAPPER ===== */
  .content-wrapper {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .task-list-container {
    flex: 1;
    overflow-y: auto;
    padding: 10px;
  }
.col-date{
   flex: 0 0 auto;
    font-size: 12px;
    opacity: 0.8;
    white-space: nowrap;
}
  .task-item {
    font-size: 13px;
    display: flex;
    align-items: center;
    padding: 8px 10px;
    margin: 6px 0;
    background-color: #444;
    color: #fff;
    border-radius: 4px;
    gap: 10px;
  }

  .task-item.completed-task {
    opacity: 0.6;
    background-color: #2E2D2D;
  }

  /* Checkbox Styles */
  .task-checkbox {
    width: 12px;
    height: 12px;
    appearance: none;
    border: 2px solid white;
    border-radius: 3px;
    background: transparent;
    cursor: pointer;
    flex-shrink: 0;
    position: relative;
  }

  .task-checkbox:checked::after {
    content: "✔";
    position: absolute;
    top: -2px;
    left: 1px;
    font-size: 10px;
    color: white;
  }
  

  .priority-HIGH { border-color: #ff4d4d; }
  .priority-MEDIUM { border-color: #ffd633; }
  .priority-LOW { border-color: #4da6ff; }

  .task-text {
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }

  .col-title { flex: 2; }
  .col-desc { flex: 3; }
  .col-assign { flex: 1.5; text-align: center; cursor: pointer;  }
  .col-assign select { background: #555; color: white; border: none; font-size: 12px; border-radius: 3px; width: 90%; }
  .col-date { flex: 1; text-align: right; }

  /* ===== SEPARATOR ===== */
  .day-separator {
    height: 1px;
    background-color: #7C7B7B;
    margin: 10px 5px;
    opacity: 0.3;
  }

  /* ===== COMPLETED SECTION ===== */
  .completed-header {
    margin: 0 10px;
    border-radius: 100px;
    background-color: #0F8989;
    padding: 8px 20px;
    font-weight: bold;
    color: white;
    margin-top: 10px;
  }

  .completed-section {
    height: 150px;
    overflow-y: auto;
    padding: 10px;
    background-color: #2E2D2D;
    color: white;
  }

</style>
</head>

<body>
<%- include('navbar') %>

<div class="layout">
  <div class="sidebar-container">
 <%- include('sidebar') %>
  </div>

  <div class="main-content">
    <div class="sub-header">
      <div class="col-title">Task</div>
      <div class="col-desc">Description</div>
      <div class="col-assign">Assigned To</div>
      <div class="col-date">Date</div>
    </div>

    <div class="content-wrapper">
      <div class="task-list-container" id="open-task-list"></div>

      <div class="completed-header">Completed Tasks</div>
      <div class="completed-section">
        <% if (completedTasks.length > 0) { %>
          <% completedTasks.forEach(task => { %>
            <div class="task-item completed-task">
              <input type="checkbox" class="task-checkbox priority-<%= task.priority %>" checked onchange="toggleStatus('<%= task.id %>', 'OPEN')">
              <div class="col-title task-text" title="<%= task.title %>"><%= task.title %></div>
              <div class="col-desc task-text" title="<%= task.description %>"><%= task.description %></div>
              <div class="col-assign task-text"><%= task.assigned_to %></div>
              <div class="col-date date-display"><%= task.due_date %></div>
            </div>
          <% }) %>
        <% } else { %>
          <div style="color: #888; padding: 10px; text-align: center;">No completed tasks.</div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<script>
const openTasks = <%- JSON.stringify(openTasks) %>;
const members = <%- JSON.stringify(members) %>;

function formatDate(dateStr) {
  if (!dateStr || dateStr === 'null') return '';
  const today = new Date();
  const tomorrow = new Date();
  tomorrow.setDate(today.getDate() + 1);
  const taskDate = new Date(dateStr);
  today.setHours(0,0,0,0); tomorrow.setHours(0,0,0,0); taskDate.setHours(0,0,0,0);

  if (taskDate.getTime() === today.getTime()) return "Today";
  else if (taskDate.getTime() === tomorrow.getTime()) return "Tom";
  else return taskDate.toLocaleDateString('en-GB', { day: '2-digit', month: 'short' });
}

async function toggleStatus(id, status) {
  const res = await fetch('/update-task-status', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id, status })
  });
  if (res.ok) window.location.reload();
}

async function changeAssignee(taskId, newAssigneeId) {
  const res = await fetch('/assign_by_me/update-assignee', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ taskId, newAssigneeId })
  });
  if (res.ok) window.location.reload();
}

function renderOpenTasks() {
  const container = document.getElementById('open-task-list');
  if (openTasks.length === 0) {
    container.innerHTML = '<div style="color: #aaa; padding: 20px; text-align: center;">No open tasks assigned by you.</div>';
    return;
  }

  const grouped = {};
  openTasks.forEach(task => {
    const d = task.due_date ? new Date(task.due_date).toDateString() : 'No Date';
    if (!grouped[d]) grouped[d] = [];
    grouped[d].push(task);
  });

  const dates = Object.keys(grouped);
  dates.forEach((date, index) => {
    grouped[date].forEach(task => {
      const item = document.createElement('div');
      item.className = 'task-item';
      
      let memberOptions = members.map(m => `<option value="${m.id}" ${m.id == task.assignee_id ? 'selected' : ''}>${m.name}</option>`).join('');

      item.innerHTML = `
        <input type="checkbox" class="task-checkbox priority-${task.priority}" onchange="toggleStatus('${task.id}', 'COMPLETED')">
        <div class="col-title task-text" title="${task.title}">${task.title}</div>
        <div class="col-desc task-text" title="${task.description}">${task.description}</div>
        <div class="col-assign">
            <select onchange="changeAssignee('${task.id}', this.value)">
                ${memberOptions}
            </select>
        </div>
        <div class="col-date">${formatDate(task.due_date)}</div>
      `;
      container.appendChild(item);
    });

    if (index < dates.length - 1) {
      const hr = document.createElement('div');
      hr.className = 'day-separator';
      container.appendChild(hr);
    }
  });
}

document.addEventListener('DOMContentLoaded', () => {
  renderOpenTasks();
  document.querySelectorAll('.completed-section .date-display').forEach(el => {
    el.innerText = formatDate(el.innerText);
  });
});
</script>

</body>
</html>
