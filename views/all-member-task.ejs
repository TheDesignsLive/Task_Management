<!DOCTYPE html>
<html>
<head>
<title>All Member Tasks</title>
<link rel="icon" type="image/svg" href="/images/tms.svg">
<style>
html,body{
  margin:0;
  padding:0;
  height:100%;
  overflow:hidden;   /* prevents page scroll */
  background:#3C3A3A;
  font-family:Arial;
}

.layout{display:flex;height:calc(100% - 60px);}
.sidebar-container{width:55px;}
.main-content{
  flex:1;
  display:flex;
  flex-direction:column;
  overflow:hidden;   /* prevent main-content from expanding */
}

.filter-section{padding:10px;}
.filter-section select{
  padding:6px 10px;
  border-radius:4px;
  border:none;
  max-width:200px;
  width:100%;
  text-overflow:ellipsis;
}

/* ===== SUB HEADER ===== */
.sub-header{
  display:flex;
  background:#CDF4F4;
  font-size:14px;
}

.sub-header div{
  display:flex;
  justify-content:center;
  align-items:center;
  padding:6px;
  flex-shrink:0;
}

.task-header{ width:475px; }
.change{ width:300px; }
.update{ width:300px; }
.other-task{ width:300px; }

/* ===== MAIN LAYOUT ===== */
.content-wrapper{
  flex:1;
  display:flex;
  overflow-x:auto;   /* horizontal scroll here */
  overflow-y:hidden;
  align-items:stretch;
}

/* LEFT TASK */
.task-main{
  flex:4;
  padding:8px;
  overflow-y:auto;
  min-width:350px;
  position:relative;
}
.task-main,
.task-change,
.task-update,
.task-other,
.completed-section{
  overflow-y:auto;
  height:100%;
   background:#2E2D2D;
}

/* RIGHT SIDE */
.right-section{
  flex:5;
  display:flex;
  flex-direction:column;
  height:100%;
   min-height:0;   /* IMPORTANT */
}

.top-columns{
  flex:1;
  display:flex;
  align-items:stretch;   /* IMPORTANT */
   min-height:0;   /* IMPORTANT */
}
.task-change,
.task-update,
.task-other{
  flex:1;
  padding:10px;
  overflow-y:auto;
  min-width:60px;
}
.vertical-line{
  width:1px;
  background:#777;
  align-self:stretch;    /* IMPORTANT */
  flex-shrink: 0;
}

/* COMPLETED */
.completed-wrapper{
  display:flex;
  flex-direction:column;
  background:#2E2D2D;
  border-left:1px solid #666;
  min-width:280px;
  flex-shrink:0;
}

.completed-header{
  height:30px;
  margin:8px 10px 0 10px;
  border-radius:100px;
  background:#0F8989;
  color:white;
  font-size:12px;
  font-weight:600;
  display:flex;
  align-items:center;
  justify-content:center;
  width:calc(100% - 20px);
}
.completed-section{
  flex:1;
  overflow-y:auto;
  padding:10px;
  color:white;
}

/* ===== TASK CARD ===== */
.task-card{
  background:#444;
  color:white;
  padding:6px;
  margin-bottom:6px;
  border-radius:4px;
  font-size:13px;
  display:flex;
  flex-direction:column;
}

.priority-red{border-left:4px solid red;}
.priority-yellow{border-left:4px solid yellow;}
.priority-blue{border-left:4px solid blue;}

.task-row{
  display:flex;
  align-items:center;
  gap:6px;
  flex:1;
  min-width:0;
}

.task-date{
  width:60px;
  text-align:right;
  font-size:11px;
  opacity:0.7;
  white-space:nowrap;
}

/* New class for task owner name */
.task-owner-name {
  font-size: 11px;
  opacity: 0.4;
  margin: 0 5px;
  max-width: 80px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-checkbox{
  width:12px;
  height:12px;
  appearance:none;
  border:2px solid white;
  border-radius:3px;
  background:transparent;
  cursor:pointer;
  position:relative;
  flex-shrink:0;
}

.task-checkbox:checked::after{
  content:"✔";
  position:absolute;
  top:0;
  left:1px;
  font-size:7px;
  color:white;
}

.checkbox-red{border-color:red;}
.checkbox-yellow{border-color:yellow;}
.checkbox-blue{border-color:blue;}

.info-icon{
  width:14px;
  height:14px;
  min-width:14px;
  flex-shrink:0;
  stroke:#959494;
  cursor:pointer;
  margin-right:6px;
}
.info-icon:hover{
  stroke:white;
}

.task-card-header{
  display:flex;
  align-items:center;
  width:100%;
  gap:8px;
}

.task-details{
  display:none;
  border-top:1px solid #777;
  margin-top:6px;
  padding-top:6px;
}

.task-card.expanded .task-details{
  display:block;
}

.task-desc-text{
  font-size:12px;
  color:#ccc;
}

.other-name{
  font-size:11px;
  opacity:0.7;
  margin-left:auto;
  white-space:nowrap;
  text-align:right;
}

.task-column{
  position:sticky;
  left:0;
  z-index:4;
  background:#3C3A3A;
  display:flex;
  flex-direction:column;
  flex:1.5;
  min-width:400px;
}

/* STICKY TASK COLUMN */
.sub-header{
  position:relative;
}

.sub-header .task-header{
  position:sticky;
  left:0;
  z-index:5;
  background:#CDF4F4;
}

.task-column{
  position:sticky;
  left:0;
  z-index:4;
  background:#3C3A3A;
    display:flex;
  flex-direction:column;
  flex:1.8;
  min-width:510px;
}

.task-column + .vertical-line{
  position:sticky;
  left:475px;
  z-index:3;
}

/* Scrollbar width */
::-webkit-scrollbar {
  width:2px;
  height:6px;
}
::-webkit-scrollbar-track {
  background:transparent;
}
::-webkit-scrollbar-thumb {
  background:#777;
  border-radius:10px;
}
::-webkit-scrollbar-thumb:hover {
  background:#aaa;
}
::-webkit-scrollbar:horizontal {
  height:16px;   /* 🔥 increase this (10–16px as you like) */
    background:#aaa;
    
}

.past-date{
 color: #ff4d4d !important;
  font-weight:500;
}

.task-main{
  flex:1;
  padding:10px;
  overflow-y:auto;
}
.column-wrapper{
  display:flex;
  flex-direction:column;
  flex:1;
  min-width:310px;
}

.column-header{
  height:30px;
  margin:8px 10px 0 10px;
  border-radius:100px;
  background:#0F8989;
  color:white;
  font-size:12px;
  font-weight:600;
  display:flex;
  align-items:center;
  justify-content:center;
  width:calc(100% - 20px);
}

.task-title{
  flex:1;
  min-width:0;
  word-break:break-word;
}

.completed-section .task-card {
  opacity: 0.5;   /* adjust: 0.3 = more faded, 0.7 = less faded */
}
</style>
</head>
<body>

<%- include('navbar') %>

<%
function getTaskDate(date){
  if(!date) return '';
  const d = new Date(date);
  const today = new Date();
  const tomorrow = new Date();
  today.setHours(0,0,0,0);
  tomorrow.setHours(0,0,0,0);
  tomorrow.setDate(tomorrow.getDate()+1);
  d.setHours(0,0,0,0);
  if(d.getTime() === today.getTime()){ return "Today"; }
  if(d.getTime() === tomorrow.getTime()){ return "Tom"; }
  const day=("0"+d.getDate()).slice(-2);
  const month=d.toLocaleString('en-GB',{month:'short'});
  return `${day} ${month}`;
}
%>

<div class="layout" id="allMemberLayout">
<div class="sidebar-container">
 <%- include('sidebar') %>
</div>

<div class="main-content" id="spaMainContent">

<div class="filter-section">
<select id="userFilter" onchange="filterUsers(this.value)">
<option value="all">All Members</option>
<% users.forEach(user => { %>
<option value="<%= user.id %>" <%= selected_user == user.id ? 'selected' : '' %>>
<%= user.name %>
</option>
<% }) %>
</select>
</div>

<div class="content-wrapper" id="taskContentArea">
  <div class="task-column">
    <div class="column-header">Task</div>
  <div class="task-main">
  <% tasks.filter(t=>t.section==='TASK' && t.status==='OPEN').forEach(task=>{ %>
<%
let taskDate=''; let isPast=false;
if(task.due_date){
  const d=new Date(task.due_date); const today=new Date(); const tomorrow=new Date();
  today.setHours(0,0,0,0); tomorrow.setHours(0,0,0,0); tomorrow.setDate(tomorrow.getDate()+1);
  d.setHours(0,0,0,0); if(d < today){ isPast=true; }
  if(d.getTime() === today.getTime()){ taskDate="Today"; }
  else if(d.getTime() === tomorrow.getTime()){ taskDate="Tom"; }
  else{ const day=("0"+d.getDate()).slice(-2); const month=d.toLocaleString('en-GB',{month:'short'}); taskDate=`${day} ${month}`; }
}
%>
  <div class="task-card priority-<%= task.priority.toLowerCase() %>">
    <div class="task-card-header">
      <div class="task-row">
        <input type="checkbox" disabled class="task-checkbox <%= task.priority==='HIGH'?'checkbox-red':'' %> <%= task.priority==='MEDIUM'?'checkbox-yellow':'' %> <%= task.priority==='LOW'?'checkbox-blue':'' %>">
        <div class="task-title"><%= task.title %></div>
      </div>
    <% if(task.description && task.description.trim() !== ''){ %>
<svg class="info-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
<circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="8.5"></line><line x1="12" y1="11" x2="12" y2="16"></line>
</svg>
<% } else { %><div style="width:14px;"></div><% } %>
     <div class="task-owner-name"><%= task.assigned_to_name %></div>
<div class="task-date <%= isPast ? 'past-date' : '' %>"><%= taskDate %></div>
    </div>
    <div class="task-details">
      <div class="task-desc-text"><%= task.description || "No description provided." %></div>
    </div>
  </div>
  <% }) %>
  </div>
  </div>
  <div class="vertical-line"></div> 

  <div class="right-section">
    <div class="top-columns">
      <div class="column-wrapper">
        <div class="column-header">Change</div>
      <div class="task-change">
      <% tasks.filter(t=>t.section==='CHANGES' && t.status==='OPEN').forEach(task=>{ %>
<%
let taskDate = getTaskDate(task.due_date);
let isPast = false;

if(task.due_date){
  const d = new Date(task.due_date);
  const today = new Date();
  today.setHours(0,0,0,0);
  d.setHours(0,0,0,0);
  if(d < today){ isPast = true; }
}
%>
      <div class="task-card priority-<%= task.priority.toLowerCase() %>">
        <div class="task-card-header">
          <div class="task-row">
            <input type="checkbox" disabled class="task-checkbox <%= task.priority==='HIGH'?'checkbox-red':'' %> <%= task.priority==='MEDIUM'?'checkbox-yellow':'' %> <%= task.priority==='LOW'?'checkbox-blue':'' %>">
            <div class="task-title"><%= task.title %></div>
          </div>
<% if(task.description && task.description.trim() !== ''){ %>
<svg class="info-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
<circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="8.5"></line><line x1="12" y1="11" x2="12" y2="16"></line>
</svg>
<% } else { %><div style="width:14px;"></div><% } %>
        <div class="task-owner-name"><%= task.assigned_to_name %></div>
<div class="task-date <%= isPast ? 'past-date' : '' %>"><%= taskDate %></div>
        </div>
        <div class="task-details">
          <div class="task-desc-text"><%= task.description || "No description provided." %></div>
        </div>
      </div>
      <% }) %>
      </div>
</div>
      <div class="vertical-line"></div> 
<div class="column-wrapper">
<div class="column-header">Update</div>
<div class="task-update">
<% tasks.filter(t=>t.section==='UPDATE' && t.status==='OPEN').forEach(task=>{ %>
<%
let taskDate = getTaskDate(task.due_date);
let isPast = false;

if(task.due_date){
  const d = new Date(task.due_date);
  const today = new Date();
  today.setHours(0,0,0,0);
  d.setHours(0,0,0,0);
  if(d < today){ isPast = true; }
}
%>
<div class="task-card priority-<%= task.priority.toLowerCase() %>">
<div class="task-card-header">
<div class="task-row">
<input type="checkbox" disabled class="task-checkbox <%= task.priority==='HIGH'?'checkbox-red':'' %> <%= task.priority==='MEDIUM'?'checkbox-yellow':'' %> <%= task.priority==='LOW'?'checkbox-blue':'' %>">
<div class="task-title"><%= task.title %></div>
</div>
<% if(task.description && task.description.trim() !== ''){ %>
<svg class="info-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
<circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="8.5"></line><line x1="12" y1="11" x2="12" y2="16"></line>
</svg>
<% } else { %><div style="width:14px;"></div><% } %>
<div class="task-owner-name"><%= task.assigned_to_name %></div>
<div class="task-date <%= isPast ? 'past-date' : '' %>"><%= taskDate %></div>
</div>
<div class="task-details"><div class="task-desc-text"><%= task.description || "No description provided." %></div></div>
</div>
<% }) %>
</div>
</div>
      <div class="vertical-line"></div> 
      <div class="column-wrapper">
        <div class="column-header">Others</div>
      <div class="task-other">
      <% tasks.filter(t=>t.section==='OTHERS' && t.status==='OPEN').forEach(task=>{ %>
      <div class="task-card priority-<%= (task.priority||'').toLowerCase() %>">
<div class="task-card-header">
<div class="task-row">
<div style="display:flex; align-items:center; gap:6px; flex:1; overflow:hidden;">
<input type="checkbox" disabled class="task-checkbox <%= task.priority==='HIGH'?'checkbox-red':'' %> <%= task.priority==='MEDIUM'?'checkbox-yellow':'' %> <%= task.priority==='LOW'?'checkbox-blue':'' %>">
<div class="task-title"><%= task.title %></div>
</div>
<% if(task.description && task.description.trim() !== ''){ %>
<svg class="info-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
<circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="8.5"></line><line x1="12" y1="11" x2="12" y2="16"></line>
</svg>
<% } else { %><div style="width:14px;"></div><% } %>
<div class="task-owner-name"><%= task.assigned_to_name %></div>
</div>
</div>
<div class="task-details"><div class="task-desc-text"><%= task.description || "No description provided." %></div></div>
</div>
      <% }) %>
      </div>
         </div>
      <div class="vertical-line"></div> 
      <div class="completed-wrapper">
        <div class="completed-header">Completed Tasks</div>
        <div class="completed-section">
        <% tasks.filter(t=>t.status==='COMPLETED').forEach(task=>{ %>
<% const taskDate = getTaskDate(task.due_date); %>
    <div class="task-card priority-<%= task.priority.toLowerCase() %>">
  <div class="task-card-header">
    <div class="task-row">
      <input type="checkbox" checked disabled class="task-checkbox <%= task.priority==='HIGH'?'checkbox-red':'' %> <%= task.priority==='MEDIUM'?'checkbox-yellow':'' %> <%= task.priority==='LOW'?'checkbox-blue':'' %>">
<div class="task-title"><%= task.title %></div>
    </div>
<div style="display:flex; flex-direction:column; align-items:flex-end;">
  <div class="task-owner-name"><%= task.assigned_to_name %></div>
  <div class="task-date"><%= taskDate %></div>
</div>
  </div>
</div>
        <% }) %>
        </div>
      </div>
    </div> </div> </div> </div>
</div>

<script>
// Logic to handle info expansion
function initExpansion() {
    document.querySelectorAll('.info-icon').forEach(icon =>{
      icon.onclick = function(e){
        e.stopPropagation();
        const card=this.closest('.task-card');
        card.classList.toggle('expanded');
      };
    });
}

// 🌟 0 REFRESH FILTER LOGIC
async function filterUsers(userId) {
    const url = `/all-member-task?user_id=${userId}`;
    try {
        const response = await fetch(url, {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        });
        const html = await response.text();
        
        // Create a temporary element to parse the returned HTML
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, 'text/html');
        const newTasks = doc.getElementById('taskContentArea').innerHTML;
        
        // Inject only the task content
        document.getElementById('taskContentArea').innerHTML = newTasks;
        
        // Update URL without refresh
        window.history.pushState({ path: url }, '', url);
        
        // Re-initialize expansion logic for new elements
        initExpansion();
        
    } catch (error) {
        console.error("Filter Error:", error);
    }
}

document.addEventListener('DOMContentLoaded', initExpansion);
</script>

<script src="/socket.io/socket.io.js"></script>
<script>
const socket = io();
socket.on('update_tasks', () => { 
    // Instead of reload, just refetch current filter
    const currentUserId = document.getElementById('userFilter').value;
    filterUsers(currentUserId);
});
</script>
</body>
</html>
