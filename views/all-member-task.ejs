<!DOCTYPE html>
<html>
<head>
<title>All Member Tasks</title>
<link rel="icon" type="image/svg" href="/images/tms.svg">
<style>
html,body{
  margin:0;
  padding:0;
  height:100%;
  overflow:hidden;   /* prevents page scroll */
  background:#3C3A3A;
  font-family:Arial;
}

.layout{display:flex;height:calc(100% - 60px);}
.sidebar-container{width:55px;}
.main-content{
  flex:1;
  display:flex;
  flex-direction:column;
  overflow:hidden;   /* prevent main-content from expanding */
}

.filter-section{padding:10px;}
.filter-section select{
  padding:6px 10px;
  border-radius:4px;
  border:none;
  max-width:200px;
  width:100%;
  text-overflow:ellipsis;
}

/* ===== SUB HEADER ===== */



.sub-header{
  display:flex;
  background:#CDF4F4;
  font-size:14px;
}

.sub-header div{
  display:flex;
  justify-content:center;
  align-items:center;
  padding:6px;
  flex-shrink:0;
}

/* match column widths */
.task-header{ width:475px; }

.change{ width:300px; }

.update{ width:300px; }

.other-task{ width:300px; }

/* ===== MAIN LAYOUT ===== */
.content-wrapper{
  flex:1;
  display:flex;
  overflow-x:auto;   /* horizontal scroll here */
  overflow-y:hidden;
  align-items:stretch;
}


.completed-wrapper{
  min-width:180px;
  flex-shrink:0;
}

/* LEFT TASK */
.task-main{
  flex:4;
  padding:8px;
  overflow-y:auto;
  min-width:350px;
}
.task-main,
.task-change,
.task-update,
.task-other,
.completed-section{
  overflow-y:auto;
  height:100%;
}

/* RIGHT SIDE */
.right-section{
  flex:5;
  display:flex;
  flex-direction:column;
  height:100%;
    min-height:0;   /* IMPORTANT */
}

.top-columns{
  flex:1;
  display:flex;
  align-items:stretch;   /* IMPORTANT */
    min-height:0;   /* IMPORTANT */
}
.task-change,
.task-update,
.task-other{
  flex:2;
  padding:8px;
  overflow-y:auto;
  min-width:300px;
}
.vertical-line{
  width:1px;
  background:#777;
  align-self:stretch;    /* IMPORTANT */
  flex-shrink: 0;
}

/* COMPLETED */
.completed-wrapper{
  display:flex;
  flex-direction:column;
  background:#2E2D2D;
  border-top:1px solid #666;
}

.completed-header{
  margin:8px;
  border-radius:50px;
  background:#0F8989;
  padding:6px 15px;
  color:white;
  font-weight:600;
  font-size:12px;
  width:calc(100% - 38px);   /* always full width */
  text-align:center;
}

.completed-section{
  flex:1;
  overflow-y:auto;
  padding:10px;
  color:white;
}

/* ===== TASK CARD ===== */
.task-card{
  background:#444;
  color:white;
  padding:6px;
  margin-bottom:6px;
  border-radius:4px;
  font-size:13px;
  display:flex;
  flex-direction:column;
}

.priority-red{border-left:4px solid red;}
.priority-yellow{border-left:4px solid yellow;}
.priority-blue{border-left:4px solid blue;}

.task-row{
  display:flex;
  align-items:center;
  gap:6px;
  flex:1;   
}

.task-date{
  font-size:11px;
  opacity:0.7;
  white-space:nowrap;
  margin-left:auto;
}

/* Checkbox */
.task-checkbox{
  width:12px;
  height:12px;
  appearance:none;
  border:2px solid white;
  border-radius:3px;
  background:transparent;
  cursor:pointer;
  position:relative;
  flex-shrink:0;
}

.task-checkbox:checked::after{
  content:"✔";
  position:absolute;
  top:0;
  left:1px;
  font-size:7px;
  color:white;
}

.checkbox-red{border-color:red;}
.checkbox-yellow{border-color:yellow;}
.checkbox-blue{border-color:blue;}

.info-icon{
  width:14px;
  height:14px;
  stroke:#959494;
  cursor:pointer;
  margin:0 10px;      /* space left & right */
  flex-shrink:0;
}
.info-icon:hover{
  stroke:white;
}

/* Header row */
.task-card-header{
  display:flex;
  align-items:center;
  width:100%;
}

/* Description hidden */
.task-details{
  display:none;
  border-top:1px solid #777;
  margin-top:6px;
  padding-top:6px;
}

/* Show when expanded */
.task-card.expanded .task-details{
  display:block;
}

.task-desc-text{
  font-size:12px;
  color:#ccc;
}

/* OTHER SECTION RIGHT NAME */
.other-name{
  font-size:11px;
  opacity:0.7;
  margin-left:auto;
  white-space:nowrap;
  text-align:right;
}

.task-main{min-width:475px;}
.task-change{min-width:300px;}
.task-update{min-width:300px;}
.task-other{min-width:300px;}
.completed-wrapper{
  min-width:10%;
  max-width:100%;
  flex-shrink:0;
}
</style>
</head>
<body>

<%- include('navbar') %>

<div class="layout">
<div class="sidebar-container">
 <%- include('sidebar') %>
</div>

<div class="main-content">

<div class="filter-section">
<form method="GET">
<select name="user_id" onchange="this.form.submit()">
<option value="all">All Members</option>
<% users.forEach(user => { %>
<option value="<%= user.id %>"
<%= selected_user == user.id ? 'selected' : '' %>>
<%= user.name %>
</option>
<% }) %>
</select>
</form>
</div>

<div class="sub-header">
  <div class="task-header">Task</div>
  <div class="right-header">
    <div class="change">Change</div>
    <div class="update">Update</div>
    <div class="other-task">Others</div>
  </div>
</div>

<div class="content-wrapper">

  <div class="task-main">
  <% tasks.filter(t=>t.section==='TASK' && t.status==='OPEN').forEach(task=>{ %>
  <% let taskDate=''; if(task.due_date){ const d=new Date(task.due_date); const day=("0"+d.getDate()).slice(-2); const month=d.toLocaleString('en-GB',{month:'short'}); taskDate=`${day} ${month}`;} %>
  <div class="task-card priority-<%= task.priority.toLowerCase() %>">
    <div class="task-card-header">
      <div class="task-row">
        <input type="checkbox" disabled class="task-checkbox 
        <%= task.priority==='HIGH'?'checkbox-red':'' %>
        <%= task.priority==='MEDIUM'?'checkbox-yellow':'' %>
        <%= task.priority==='LOW'?'checkbox-blue':'' %>">
        <div style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
          <%= task.title %>
        </div>
      </div>
        <svg class="info-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="8" x2="12" y2="8.5"></line>
          <line x1="12" y1="11" x2="12" y2="16"></line>
        </svg>
      <div class="task-date"><%= taskDate %></div>
    </div>
    <div class="task-details">
      <div class="task-desc-text">
        <%= task.description || "No description provided." %>
      </div>
    </div>
  </div>
  <% }) %>
  </div>

  <div class="vertical-line"></div> 

  <div class="right-section">
    <div class="top-columns">
      
      <div class="task-change">
      <% tasks.filter(t=>t.section==='CHANGES' && t.status==='OPEN').forEach(task=>{ %>
      <% let taskDate=''; if(task.due_date){ const d=new Date(task.due_date); const day=("0"+d.getDate()).slice(-2); const month=d.toLocaleString('en-GB',{month:'short'}); taskDate=`${day} ${month}`;} %>
      <div class="task-card priority-<%= task.priority.toLowerCase() %>">
        <div class="task-card-header">
          <div class="task-row">
            <input type="checkbox" disabled class="task-checkbox 
            <%= task.priority==='HIGH'?'checkbox-red':'' %>
            <%= task.priority==='MEDIUM'?'checkbox-yellow':'' %>
            <%= task.priority==='LOW'?'checkbox-blue':'' %>">
            <div style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
              <%= task.title %>
            </div>
          </div>
          <svg class="info-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="8" x2="12" y2="8.5"></line>
            <line x1="12" y1="11" x2="12" y2="16"></line>
          </svg>
          <div class="task-date"><%= taskDate %></div>
        </div>
        <div class="task-details">
          <div class="task-desc-text">
            <%= task.description || "No description provided." %>
          </div>
        </div>
      </div>
      <% }) %>
      </div>

      <div class="vertical-line"></div> 

      <div class="task-update">
      <% tasks.filter(t=>t.section==='UPDATE' && t.status==='OPEN').forEach(task=>{ %>
      <% let taskDate=''; if(task.due_date){ const d=new Date(task.due_date); const day=("0"+d.getDate()).slice(-2); const month=d.toLocaleString('en-GB',{month:'short'}); taskDate=`${day} ${month}`;} %>
      <div class="task-card priority-<%= task.priority.toLowerCase() %>">
        <div class="task-row">
          <input type="checkbox" disabled class="task-checkbox 
          <%= task.priority==='HIGH'?'checkbox-red':'' %>
          <%= task.priority==='MEDIUM'?'checkbox-yellow':'' %>
          <%= task.priority==='LOW'?'checkbox-blue':'' %>">
          <%= task.title %>
          <div class="task-date"><%= taskDate %></div>
        </div>
      </div>
      <% }) %>
      </div>

      <div class="vertical-line"></div> 

      <div class="task-other">
      <% tasks.filter(t=>t.section==='OTHERS' && t.status==='OPEN').forEach(task=>{ %>
      <div class="task-card priority-<%= (task.priority||'').toLowerCase() %>">
        <div class="task-row">
          <div style="display:flex; align-items:center; gap:6px; flex:1; overflow:hidden;">
            <input type="checkbox" disabled class="task-checkbox 
            <%= task.priority==='HIGH'?'checkbox-red':'' %>
            <%= task.priority==='MEDIUM'?'checkbox-yellow':'' %>
            <%= task.priority==='LOW'?'checkbox-blue':'' %>">
            <div style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
              <%= task.title %>
            </div>
          </div>
          <div class="other-name">
            <% if(selected_user === 'all'){ %>
              <%= task.assigned_by_name %> → <%= task.assigned_to_name %>
            <% } else { %>
              <%= task.assigned_by_name %>
            <% } %>
          </div>
        </div>
      </div>
      <% }) %>
      </div>

      <div class="vertical-line"></div> 

      <div class="completed-wrapper">
        <div class="completed-header">Completed Tasks</div>
        <div class="completed-section">
        <% tasks.filter(t=>t.status==='COMPLETED').forEach(task=>{ %>
        <% let taskDate=''; if(task.due_date){ const d=new Date(task.due_date); const day=("0"+d.getDate()).slice(-2); const month=d.toLocaleString('en-GB',{month:'short'}); taskDate=`${day} ${month}`;} %>
        <div class="task-card priority-<%= task.priority.toLowerCase() %>">
          <div class="task-row">
            <input type="checkbox" checked disabled class="task-checkbox 
            <%= task.priority==='HIGH'?'checkbox-red':'' %>
            <%= task.priority==='MEDIUM'?'checkbox-yellow':'' %>
            <%= task.priority==='LOW'?'checkbox-blue':'' %>">
            <%= task.title %> - <%= task.assigned_to_name %>
            <div class="task-date"><%= taskDate %></div>
          </div>
        </div>
        <% }) %>
        </div>
      </div>

    </div> </div> </div> </div>
</div>

<script>
function attachIconEvents() {
  document.querySelectorAll(".info-icon").forEach(icon => {
      icon.replaceWith(icon.cloneNode(true));
  });
  document.querySelectorAll(".info-icon").forEach(icon => {
    icon.addEventListener("click", function(e){
      e.stopPropagation();
      const card = this.closest(".task-card");
      document.querySelectorAll(".task-card").forEach(c=>{
        if(c !== card) c.classList.remove("expanded");
      });
      card.classList.toggle("expanded");
    });
  });
}

document.addEventListener("DOMContentLoaded", function(){
  attachIconEvents();
  document.addEventListener("click", function(){
    document.querySelectorAll(".task-card").forEach(c=>{
      c.classList.remove("expanded");
    });
  });
});

let silentReloadTimer = null;
function silentReload() {
    clearTimeout(silentReloadTimer);
    silentReloadTimer = setTimeout(() => {
        fetch(window.location.href) 
        .then(res => res.text())
        .then(html => {
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            const newContent = doc.querySelector('.content-wrapper');
            if (newContent) {
                document.querySelector('.content-wrapper').innerHTML = newContent.innerHTML;
                attachIconEvents(); 
            }
        })
        .catch(err => console.error("Silent reload failed", err));
    }, 300);
}

function markCompleted(taskId){
  fetch(`/complete-task/${taskId}`, { method:'POST' })
  .then(res=>res.json())
  .then(data=>{
    if(data.success) silentReload();
    else alert('Error completing task');
  });
}
</script>

<script src="/socket.io/socket.io.js"></script>
<script>
const socket = io();
const eventsToWatch = ['update_tasks', 'task_added', 'task_edited', 'task_deleted', 'task_status_changed', 'task_section_changed', 'task_assignee_changed', 'completed_deleted', 'abm_task_deleted', 'abm_completed_deleted', 'abm_assignee_changed'];
eventsToWatch.forEach(evt => { socket.on(evt, silentReload); });
</script>

</body>
</html>