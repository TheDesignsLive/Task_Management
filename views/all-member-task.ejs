<!DOCTYPE html>
<html>
<head>
<title>All Member Tasks</title>

<style>
html,body{
  margin:0;
  padding:0;
  height:100%;
  overflow:hidden;
  background:#3C3A3A;
  font-family:Arial;
}

.layout{display:flex;height:calc(100% - 60px);}
.sidebar-container{width:55px;}
.main-content{flex:1;display:flex;flex-direction:column;}

.filter-section{padding:10px;}
.filter-section select{
  padding:6px 10px;
  border-radius:4px;
  border:none;
}

.sub-header{
  display:flex;
  background:#CDF4F4;
  padding:6px;
  font-size:14px;
}
.sub-header div{text-align:center;padding:4px;border-radius:5px;}

.task{flex:4;}
.change{flex:1.5;}
.update{flex:1.5;}
.other-task{flex:2;}

.content-wrapper{flex:1;display:flex;flex-direction:column;overflow:hidden;}
.task-container{flex:1;display:flex;overflow:hidden;}

.task-box{padding:8px;overflow-y:auto;}
.task-main{flex:4;}
.task-change{flex:1.5;}
.task-update{flex:1.5;}
.task-other{flex:2;}

.vertical-line{width:1px;background:#777;}

.task-card{
  background:#444;
  color:white;
  padding:6px;
  margin-bottom:6px;
  border-radius:4px;

  font-size:13px;   /* updated font size */
  display: flex; 
    justify-content: space-between;
}

.priority-red{border-left:4px solid red;}
.priority-yellow{border-left:4px solid yellow;}
.priority-blue{border-left:4px solid blue;}

.task-row{
  display:flex;
  align-items:center;
  gap:6px;
}
.task-checkbox{
  width:14px;
  height:14px;
  appearance:none;
  border:2px solid white;
  border-radius:3px;
  background:transparent;
  cursor:pointer;
}

.checkbox-red{
  border-color:red;
}

.checkbox-yellow{
  border-color:yellow;
}

.checkbox-blue{
  border-color:blue;
}

.completed-header{
  margin:5px 10px;
  border-radius:100px;
  background:#0F8989;
  padding:6px 20px;
  color:white;
  font-weight:bold;
}

.completed-section{
  height:140px;
  overflow-y:auto;
  padding:10px;
  background:#2E2D2D;
  color:white;
}
</style>
</head>

<body>

<%- include('navbar') %>

<div class="layout">

<div class="sidebar-container">
<% if (session.show_sidebar === 'sidebar') { %>
  <%- include('sidebar') %>
<% } else if (session.show_sidebar === 'partial_sidebar') { %>
  <%- include('partial_sidebar') %>
<% } else if (session.show_sidebar === 'user_sidebar') { %>
  <%- include('user_sidebar') %>
<% } %>
</div>

<div class="main-content">

<div class="filter-section">
<form method="GET">
<select name="user_id" onchange="this.form.submit()">
<option value="all">All Employees</option>
<% users.forEach(user => { %>
<option value="<%= user.id %>"
<%= selected_user == user.id ? 'selected' : '' %>>
<%= user.name %>
</option>
<% }) %>
</select>
</form>
</div>

<div class="sub-header">
<div class="task">Task</div>
<div class="change">Change</div>
<div class="update">Update</div>
<div class="other-task">Others</div>
</div>

<div class="content-wrapper">

<div class="task-container">

<!-- TASK -->
<div class="task-box task-main">
 <% tasks.filter(t=>t.section==='TASK' && t.status==='OPEN').forEach(task=>{ %>
    <% 
      // ✅ MARK 100%: Format date like homepage
      let taskDate = '';
      if(task.due_date){
        const d = new Date(task.due_date);
        const day = ("0"+d.getDate()).slice(-2);
        const month = d.toLocaleString('en-GB',{month:'short'});
        taskDate = `${day} ${month}`;
      }
    %>

<div class="task-card priority-<%= task.priority.toLowerCase() %>">
  <div class="task-row">
    <input type="checkbox"
      class="task-checkbox 
      <%= task.priority === 'HIGH' ? 'checkbox-red' : '' %>
      <%= task.priority === 'MEDIUM' ? 'checkbox-yellow' : '' %>
      <%= task.priority === 'LOW' ? 'checkbox-blue' : '' %>">
    <b><%= task.title %></b>
  </div>
  <div class="task-date"><%= taskDate %></div>
</div>
<% }) %>
</div>

<div class="vertical-line"></div>

<!-- CHANGE -->
<div class="task-box task-change">
<% tasks.filter(t=>t.section==='CHANGES' && t.status==='OPEN')
.forEach(task=>{ %>
<div class="task-card priority-<%= task.priority.toLowerCase() %>">
<b><%= task.title %></b>
</div>
<% }) %>
</div>

<div class="vertical-line"></div>

<!-- UPDATE -->
<div class="task-box task-update">
<% tasks.filter(t=>t.section==='UPDATE' && t.status==='OPEN')
.forEach(task=>{ %>
<div class="task-card priority-<%= task.priority.toLowerCase() %>">
<b><%= task.title %></b>
</div>
<% }) %>
</div>

<div class="vertical-line"></div>

<!-- OTHERS -->
<div class="task-box task-other">
<% tasks.filter(t=>t.section==='OTHERS' && t.status==='OPEN')
.forEach(task=>{ %>
<div class="task-card priority-<%= task.priority.toLowerCase() %>">
<b><%= task.title %></b>
</div>
<% }) %>
</div>

</div>

<div class="completed-header">Completed Tasks</div>

<div class="completed-section">
<% tasks.filter(t=>t.status==='COMPLETED')
.forEach(task=>{ %>
<div class="task-card">
✔ <%= task.title %> ( <%= task.assigned_to_name %> )
</div>
<% }) %>
</div>

</div>
</div>
</div>

</body>
</html>